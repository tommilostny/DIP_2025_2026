@page "/submit-job"
@rendermode InteractiveServer
@inject ActorSystem ActorSystem
@inject NavigationManager NavigationManager
@inject WordlistService WordlistService
@inject MaskService MaskService

<PageTitle>Submit Job</PageTitle>

<h1>Submit New Job</h1>

<EditForm Model="Model" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />
    <div class="row">
        <div class="col-md-6">
            
            <div class="mb-3">
                <label class="form-label">Attack Mode</label>
                <InputSelect @bind-Value="Model!.AttackMode" class="form-select">
                    <option value="@AttackMode.Mask">Mask Attack</option>
                    <option value="@AttackMode.Dictionary">Dictionary Attack</option>
                    <option value="@AttackMode.Combinator">Combinator Attack</option>
                    <option value="@AttackMode.Hybrid_WordlistMask">Hybrid Wordlist + Mask</option>
                    <option value="@AttackMode.Hybrid_MaskWordlist">Hybrid Mask + Wordlist</option>
                    <option value="@AttackMode.Association">Association Attack</option>
                </InputSelect>
            </div>

            <div class="mb-3">
                <label class="form-label">Hashes (one per line)</label>
                <InputTextArea @bind-Value="Model.Hashes" class="form-control" rows="4" />
                <ValidationMessage For="() => Model.Hashes" />

                <div class="mt-2">
                    <label class="form-label small text-muted">Load hashes from file (.txt, .hashes)</label>
                    <InputFile OnChange="@(e => LoadContentFromFileAsync(e, () => Model.Hashes, val => Model.Hashes = val))" class="form-control form-control-sm" accept=".txt,.hashes" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Hash Type</label>
                <InputText @bind-Value="Model.HashType" class="form-control" list="hashTypeList" placeholder="Search by name or type ID... (e.g. 0)" />
                <datalist id="hashTypeList">
                    @foreach (var hashType in HashTypeMap.Map)
                    {
                        <option value="@hashType.Key">@hashType.Value</option>
                    }
                </datalist>
                <ValidationMessage For="() => Model.HashType" />
                <div class="form-text text-muted">Select from the list or type the Hashcat mode number manually.</div>
            </div>

            <div class="mb-3">
                <label class="form-label">Chunk Time (seconds)</label>
                <InputNumber @bind-Value="Model.ChunkTimeSeconds" class="form-control" />
                <ValidationMessage For="() => Model.ChunkTimeSeconds" />
                <div class="form-text text-muted">Target time for each work chunk assigned to agents.</div>
            </div>
        </div>

        <div class="col-md-6">
            @if (Model.AttackMode == AttackMode.Mask)
            {
                <div class="card mb-3">
                    <div class="card-header">Mask Attack Settings</div>
                    <div class="card-body">
                        <MaskSelection @bind-Masks="Model.Masks"
                                       SavedMasks="_savedMasks"
                                       ValidationFor="() => Model.Masks"
                                       OnLoadFile="OnMaskFileSelected"
                                       OnAddMask="AddMaskToInput"
                                       OnDeleteMask="DeleteSavedMask" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Min Length</label>
                                <InputNumber @bind-Value="Model.MinLength" class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Max Length</label>
                                <InputNumber @bind-Value="Model.MaxLength" class="form-control" />
                            </div>
                        </div>
                        <div class="form-text text-muted">Leave Min/Max Length as -1 to disable increment mode.</div>

                        <hr />
                        <h6>Custom Character Sets</h6>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Charset 1 (?1)</label>
                                <InputText @bind-Value="Model.CustomCharset1" class="form-control" placeholder="e.g. ?l?d" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Charset 2 (?2)</label>
                                <InputText @bind-Value="Model.CustomCharset2" class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Charset 3 (?3)</label>
                                <InputText @bind-Value="Model.CustomCharset3" class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Charset 4 (?4)</label>
                                <InputText @bind-Value="Model.CustomCharset4" class="form-control" />
                            </div>
                        </div>
                    </div>
                </div>
            }
            else if (Model.AttackMode == AttackMode.Dictionary)
            {
                <div class="card mb-3">
                    <div class="card-header">Dictionary Attack Settings</div>
                    <div class="card-body">
                        <WordlistSelection Title="Available Wordlists"
                                           AvailableWordlists="_availableWordlists"
                                           AllowMultiple="true"
                                           @bind-SelectedWordlists="Model.Wordlists"
                                           ValidationFor="() => Model.Wordlists"
                                           HelpText="Select one or more wordlists for the dictionary attack." />

                        <RulesSelection @bind-RuleContent="Model.DictionaryRules"
                                        OnLoadFile="OnDictionaryRulesFileSelected" />
                    </div>
                </div>
            }
            else if (Model.AttackMode == AttackMode.Combinator)
            {
                <div class="card mb-3">
                    <div class="card-header">Combinator Attack Settings</div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <WordlistSelection Title="Left Wordlist"
                                                   AvailableWordlists="_availableWordlists"
                                                   AllowMultiple="true"
                                                   @bind-SelectedWordlists="Model.LeftWordlists"
                                                   ValidationFor="() => Model.LeftWordlists"
                                                   HelpText="Choose the left-side wordlist for the combinator attack." />
                            </div>
                            <div class="col-md-6 mb-3">
                                <WordlistSelection Title="Right Wordlist"
                                                   AvailableWordlists="_availableWordlists"
                                                   AllowMultiple="true"
                                                   @bind-SelectedWordlists="Model.RightWordlists"
                                                   ValidationFor="() => Model.RightWordlists"
                                                   HelpText="Choose the right-side wordlist for the combinator attack." />
                            </div>
                        </div>
                        <div class="form-text text-muted">The coordinator will combine the selected left and right wordlists into candidate pairs.</div>
                    </div>
                </div>
            }

            <ValidationSummary class="text-danger" />

            <button type="submit" class="btn btn-primary mb-5" disabled="@_isSubmitting">Submit Job</button>
        </div>
    </div>
</EditForm>

@code {
    public SubmitJobViewModel? Model { get; set; }

    private bool _isSubmitting;
    private List<string> _availableWordlists = [];
    private IReadOnlyList<string> _savedMasks = [];

    protected override void OnInitialized()
    {
        Model ??= new();
        _savedMasks = MaskService.GetSavedMasks();
        _availableWordlists = WordlistService.GetAvailableWordlists().ToList();
    }
    
    private async Task LoadContentFromFileAsync(InputFileChangeEventArgs e, Func<string?> getter, Action<string> setter)
    {
        var file = e.File;
        if (file is null) return;

        // Set a reasonable file size limit to prevent browser issues (e.g., 10MB)
        const long maxFileSize = 10 * 1024 * 1024;

        try
        {
            await using var stream = file.OpenReadStream(maxFileSize);
            using var reader = new StreamReader(stream);
            var fileContent = await reader.ReadToEndAsync(CancellationToken.None);

            if (!string.IsNullOrWhiteSpace(fileContent))
            {
                var currentValue = getter();
                setter(string.IsNullOrWhiteSpace(currentValue) ? fileContent : $"{currentValue.TrimEnd()}\n{fileContent}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error reading file: {ex.Message}");
        }
    }

    private Task OnMaskFileSelected(InputFileChangeEventArgs e)
        => LoadContentFromFileAsync(e, () => Model!.Masks, val => Model!.Masks = val);

    private Task OnDictionaryRulesFileSelected(InputFileChangeEventArgs e)
        => LoadContentFromFileAsync(e, () => Model!.DictionaryRules, val => Model!.DictionaryRules = val);

    private void AddMaskToInput(string mask)
    {
        if (string.IsNullOrWhiteSpace(Model!.Masks))
        {
            Model.Masks = mask;
        }
        else
        {
            // Append on a new line
            Model.Masks += $"\n{mask}";
        }
    }

    private void DeleteSavedMask(string mask)
    {
        try
        {
            MaskService.DeleteMask(mask);
            _savedMasks = MaskService.GetSavedMasks();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting mask: {ex.Message}");
        }
    }

    private async Task HandleValidSubmit()
    {
        if (Model is null) return;

        _isSubmitting = true;
        try
        {
            var hashes = Model.Hashes?
                .Split(['\r', '\n'], StringSplitOptions.RemoveEmptyEntries)
                .Select(h => h.Trim())
                .Where(h => !string.IsNullOrWhiteSpace(h))
                .ToHashSet();
            var jobManager = ActorSystem.Cluster().GetJobManagerGrain("root");

            var jobSpecs = new JobSpecsEnvelope
            {
                Hashes = { hashes },
                HashType = int.Parse(Model.HashType),
                ChunkTimeSeconds = (uint)(Model.ChunkTimeSeconds > 0 ? Model.ChunkTimeSeconds : Constants.DefaultChunkTimeSeconds)
            };

            switch (Model.AttackMode)
            {
            case AttackMode.Mask:
                var masks = Model.Masks!
                    .Split(['\r', '\n'], StringSplitOptions.RemoveEmptyEntries)
                    .Select(m => m.Trim())
                    .Where(m => !string.IsNullOrWhiteSpace(m))
                    .ToHashSet();

                jobSpecs.MaskJobSpecs = new HashcatMaskJobSpecs
                {
                    Masks = { masks },
                    MinLength = Model.MinLength,
                    MaxLength = Model.MaxLength,
                    CustomCharset1 = Model.CustomCharset1 ?? "",
                    CustomCharset2 = Model.CustomCharset2 ?? "",
                    CustomCharset3 = Model.CustomCharset3 ?? "",
                    CustomCharset4 = Model.CustomCharset4 ?? "",
                };
                await jobManager.JobSubmission(jobSpecs, CancellationToken.None);
                
                // Save the valid masks for future use
                MaskService.SaveMasks(masks);
                break;
        
            case AttackMode.Dictionary:
                var wordlists = Model.Wordlists?.Split(['\r', '\n'], StringSplitOptions.RemoveEmptyEntries) ?? [];
                var dictionaryRuleContent = string.Join('\n', (Model.DictionaryRules ?? string.Empty)
                    .Split(['\r', '\n'], StringSplitOptions.RemoveEmptyEntries)
                    .Select(r => r.Trim())
                    .Where(r => !string.IsNullOrWhiteSpace(r) && !r.StartsWith('#')));

                jobSpecs.DictionaryJobSpecs = new HashcatDictionaryJobSpecs
                {
                    Wordlists = { wordlists },
                    RuleFileContent = dictionaryRuleContent
                };
                await jobManager.JobSubmission(jobSpecs, CancellationToken.None);
                break;

            case AttackMode.Combinator:
                var leftWordlists = Model.LeftWordlists?.Split(['\r', '\n'], StringSplitOptions.RemoveEmptyEntries) ?? [];
                var rightWordlists = Model.RightWordlists?.Split(['\r', '\n'], StringSplitOptions.RemoveEmptyEntries) ?? [];

                jobSpecs.CombinatorJobSpecs = new HashcatCombinatorJobSpecs
                {
                    LeftWordlists = { leftWordlists },
                    RightWordlists = { rightWordlists },
                    RuleFileContent = string.Empty // TODO: add dedicated combinator rule input if needed
                };
                await jobManager.JobSubmission(jobSpecs, CancellationToken.None);
                break;
            }

            NavigationManager.NavigateTo("/");
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
