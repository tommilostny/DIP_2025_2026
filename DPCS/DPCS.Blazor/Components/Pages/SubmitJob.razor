@page "/submit-job"
@rendermode InteractiveServer
@inject ActorSystem ActorSystem
@inject NavigationManager NavigationManager

<PageTitle>Submit Job</PageTitle>

<h1>Submit New Job</h1>

<div class="row">
    <div class="col-md-6">
        <EditForm Model="Model" OnValidSubmit="HandleValidSubmit" FormName="SubmitJobForm">
            <DataAnnotationsValidator />
            
            <div class="mb-3">
                <label class="form-label">Attack Mode</label>
                <InputSelect @bind-Value="Model!.AttackMode" class="form-select">
                    <option value="@AttackMode.Mask">Mask Attack</option>
                    <option value="@AttackMode.Dictionary">Dictionary Attack</option>
                </InputSelect>
            </div>

            <div class="mb-3">
                <label class="form-label">Hashes (one per line)</label>
                <InputTextArea @bind-Value="Model.Hashes" class="form-control" rows="4" />
                <ValidationMessage For="() => Model.Hashes" />
            </div>

            <div class="mb-3">
                <label class="form-label">Hash Type</label>
                <InputText @bind-Value="Model.HashType" class="form-control" list="hashTypeList" placeholder="Search by name or type ID... (e.g. 0)" />
                <datalist id="hashTypeList">
                    @foreach (var hashType in HashTypeMap.Map)
                    {
                        <option value="@hashType.Key">@hashType.Value</option>
                    }
                </datalist>
                <ValidationMessage For="() => Model.HashType" />
                <div class="form-text text-muted">Select from the list or type the Hashcat mode number manually.</div>
            </div>

            @if (Model.AttackMode == AttackMode.Mask)
            {
                <div class="card mb-3">
                    <div class="card-header">Mask Attack Settings</div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">
                                Mask
                                <button type="button" class="btn btn-sm btn-link p-0 ms-1 text-decoration-none" @onclick="() => _showMaskHelp = true" title="Show Mask Help">
                                    &#x24D8;
                                </button>
                            </label>
                            <InputText @bind-Value="Model.Mask" class="form-control" placeholder="?u?l?d?s?a" />
                            <ValidationMessage For="() => Model.Mask" />
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Min Length</label>
                                <InputNumber @bind-Value="Model.MinLength" class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Max Length</label>
                                <InputNumber @bind-Value="Model.MaxLength" class="form-control" />
                            </div>
                        </div>
                        <div class="form-text text-muted">Leave Min/Max Length as -1 to disable increment mode.</div>
                        
                        <hr />
                        <h6>Custom Character Sets</h6>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Charset 1 (?1)</label>
                                <InputText @bind-Value="Model.CustomCharset1" class="form-control" placeholder="e.g. ?l?d" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Charset 2 (?2)</label>
                                <InputText @bind-Value="Model.CustomCharset2" class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Charset 3 (?3)</label>
                                <InputText @bind-Value="Model.CustomCharset3" class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Charset 4 (?4)</label>
                                <InputText @bind-Value="Model.CustomCharset4" class="form-control" />
                            </div>
                        </div>
                    </div>
                </div>

                @if (_showMaskHelp)
                {
                    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);" @onclick="() => _showMaskHelp = false">
                        <div class="modal-dialog modal-dialog-centered modal-lg" @onclick:stopPropagation="true">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title">Hashcat Built-in Charsets</h5>
                                    <button type="button" class="btn-close" @onclick="() => _showMaskHelp = false"></button>
                                </div>
                                <div class="modal-body">
                                    <table class="table table-bordered table-sm mb-0">
                                        <thead>
                                            <tr>
                                                <th>Placeholder</th>
                                                <th>Characters</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr><td><code>?l</code></td><td>abcdefghijklmnopqrstuvwxyz</td></tr>
                                            <tr><td><code>?u</code></td><td>ABCDEFGHIJKLMNOPQRSTUVWXYZ</td></tr>
                                            <tr><td><code>?d</code></td><td>0123456789</td></tr>
                                            <tr><td><code>?h</code></td><td>0123456789abcdef</td></tr>
                                            <tr><td><code>?H</code></td><td>0123456789ABCDEF</td></tr>
                                            <tr><td><code>?s</code></td><td>«space»!"#$%&amp;'()*+,-./:;&lt;=&gt;?@@[\]^_`{|}~</td></tr>
                                            <tr><td><code>?a</code></td><td>?l?u?d?s</td></tr>
                                            <tr><td><code>?b</code></td><td>0x00 - 0xff</td></tr>
                                        </tbody>
                                    </table>
                                    
                                    <h6 class="mt-3">Custom Charsets</h6>
                                    <p class="mb-0 small">
                                        You can define up to 4 custom character sets using the fields provided. Reference them in your mask using <code>?1</code>, <code>?2</code>, <code>?3</code>, and <code>?4</code>.
                                        <br/><strong>Example:</strong> If Charset 1 is <code>?l?d</code>, a mask of <code>?1?1?1</code> will test all 3-character combinations of lowercase letters and digits.
                                    </p>
                                </div>
                                <div class="modal-footer" style="justify-content: flex-start;">
                                    <p class="mb-0 small">
                                        More info about mask attack submission: <a href="https://hashcat.net/wiki/doku.php?id=mask_attack" target="_blank">https://hashcat.net/wiki/doku.php?id=mask_attack</a>
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else if (Model.AttackMode == AttackMode.Dictionary)
            {
                <div class="card mb-3">
                    <div class="card-header">Dictionary Attack Settings</div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Wordlists (one path per line)</label>
                            <InputTextArea @bind-Value="Model.Wordlists" class="form-control" rows="3" />
                            <ValidationMessage For="() => Model.Wordlists" />
                        </div>
                    </div>
                </div>
            }

            <ValidationSummary class="text-danger" />

            <button type="submit" class="btn btn-primary mb-5" disabled="@_isSubmitting">Submit Job</button>
        </EditForm>
    </div>
</div>

@code {
    [SupplyParameterFromForm]
    public SubmitJobViewModel? Model { get; set; }

    private bool _isSubmitting;
    private bool _showMaskHelp;

    protected override void OnInitialized()
    {
        Model ??= new();
    }

    private async Task HandleValidSubmit()
    {
        if (Model is null) return;

        _isSubmitting = true;
        try
        {
            var hashes = Model.Hashes?.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries) ?? Array.Empty<string>();
            var jobManager = ActorSystem.Cluster().GetJobManagerGrain("root");

            if (Model.AttackMode == AttackMode.Mask)
            {
                var request = new HashcatMaskJobSpecs
                {
                    Hashes = { hashes },
                    Mask = Model.Mask,
                    MinLength = Model.MinLength,
                    MaxLength = Model.MaxLength,
                    HashType = int.Parse(Model.HashType),
                    CustomCharset1 = Model.CustomCharset1 ?? "",
                    CustomCharset2 = Model.CustomCharset2 ?? "",
                    CustomCharset3 = Model.CustomCharset3 ?? "",
                    CustomCharset4 = Model.CustomCharset4 ?? ""
                };
                await jobManager.MaskJobSubmission(request, CancellationToken.None);
            }
            else if (Model.AttackMode == AttackMode.Dictionary)
            {
                var wordlists = Model.Wordlists?.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries) ?? Array.Empty<string>();

                var request = new HashcatDictionaryJobSpecs
                {
                    Hashes = { hashes },
                    Wordlists = { wordlists },
                    HashType = int.Parse(Model.HashType),
                };
                await jobManager.DictionaryJobSubmission(request, CancellationToken.None);
            }

            NavigationManager.NavigateTo("/");
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
