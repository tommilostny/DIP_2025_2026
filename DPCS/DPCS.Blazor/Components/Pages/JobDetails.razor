@page "/job-details/{*JobId}"
@rendermode InteractiveServer
@using DPCS.DAL
@using DPCS.DAL.Entities
@using DPCS.Shared
@using Microsoft.EntityFrameworkCore
@inject ActorSystem ActorSystem
@inject IDbContextFactory<DpcsDbContext> DbFactory
@inject WordlistService WordlistService
@implements IDisposable

<PageTitle>Job Details</PageTitle>

<div class="mb-4">
    @if (_jobStatus is not null)
    {
        <a href="/" class="text-decoration-none">&larr; Back to Dashboard</a>
    }
    else
    {
        @if (_dbJob is not null)
        {
            <a href="job-history" class="text-decoration-none">&larr; Back to History</a>
        }
    }
</div>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1>Job Details</h1>
        <h5 class="text-muted font-monospace mb-0">@JobId</h5>
    </div>
    <button class="btn btn-outline-secondary" @onclick="LoadData">Refresh</button>
</div>

@if (_isLoading)
{
    <div class="spinner-border" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
}
else if (_dbJob is null && _jobStatus is null)
{
    <div class="alert alert-warning">Job not found.</div>
}
else
{
    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-header bg-light">
                    <strong>Configuration</strong>
                </div>
                <div class="card-body">
                    <p>
                        <strong>Attack mode:</strong> @(_dbJob?.AttackMode ?? 0) 
                        (@( _dbJob?.AttackMode == (int)AttackMode.Mask ? "Mask" : "Dictionary" ))
                    </p>
                    
                    @switch (_jobSpecs)
                    {
                    case { PayloadCase: JobSpecsEnvelope.PayloadOneofCase.MaskJobSpecs }:
                        <p><strong>Masks: </strong></p>
                        <ul>
                            @foreach (var mask in _jobSpecs.MaskJobSpecs.Masks)
                            {
                                <li class="font-monospace">@mask</li>
                            }
                        </ul>
                        @if (!string.IsNullOrWhiteSpace(_jobSpecs.MaskJobSpecs.CustomCharset1))
                        {
                            <p class="mb-1"><strong>Charset 1 (?1): </strong> @_jobSpecs.MaskJobSpecs.CustomCharset1</p>
                        }
                        @if (!string.IsNullOrWhiteSpace(_jobSpecs.MaskJobSpecs.CustomCharset2))
                        {
                            <p class="mb-1"><strong>Charset 2 (?2): </strong> @_jobSpecs.MaskJobSpecs.CustomCharset2</p>
                        }
                        @if (!string.IsNullOrWhiteSpace(_jobSpecs.MaskJobSpecs.CustomCharset3))
                        {
                            <p class="mb-1"><strong>Charset 3 (?3): </strong> @_jobSpecs.MaskJobSpecs.CustomCharset3</p>
                        }
                        @if (!string.IsNullOrWhiteSpace(_jobSpecs.MaskJobSpecs.CustomCharset4))
                        {
                            <p class="mb-1"><strong>Charset 4 (?4): </strong> @_jobSpecs.MaskJobSpecs.CustomCharset4</p>
                        }
                        break;

                    case { PayloadCase: JobSpecsEnvelope.PayloadOneofCase.DictionaryJobSpecs }:
                        <strong>Wordlists:</strong>
                        <ul>
                            @foreach (var wordlist in _jobSpecs.DictionaryJobSpecs.Wordlists)
                            {
                                <li>@wordlist</li>
                            }
                        </ul>
                        break;
                    }

                    <p class="mt-3">
                        <strong>Hash type:</strong> @(_dbJob?.HashType ?? 0) (@HashTypeMap.GetHashTypeName(_dbJob?.HashType ?? 0))
                    </p>

                    <strong style="cursor: pointer;" @onclick="ToggleHashes" class="d-block mb-2">
                        Hashes (@(_hashes.Count))
                        <span class="float-end">@(_isHashesExpanded ? "▼" : "▶")</span>
                    </strong>
                    @if (_isHashesExpanded && _hashes.Count > 0)
                    {
                        <div class="bg-light p-2 rounded" style="max-height: 200px; overflow-y: auto;">
                            <ul class="mb-0 font-monospace small" style="word-break: break-all;">
                                @foreach (var hash in _hashes)
                                {
                                    <li>@hash</li>
                                }
                            </ul>
                        </div>
                    }

                    @if (_rules.Count > 0)
                    {
                        <strong style="cursor: pointer;" @onclick="ToggleRules" class="d-block mt-3 mb-2">
                            Rules (@_rules.Count)
                            <span class="float-end">@(_isRulesExpanded ? "▼" : "▶")</span>
                        </strong>
                        @if (_isRulesExpanded)
                        {
                            <div class="bg-light p-2 rounded" style="max-height: 200px; overflow-y: auto;">
                                <ul class="mb-0 font-monospace small" style="word-break: break-all;">
                                    @foreach (var rule in _rules)
                                    {
                                        <li>@rule</li>
                                    }
                                </ul>
                            </div>
                        }
                    }

                    <p class="mt-3 mb-0"><strong>Chunk Attack seconds:</strong> @(_jobStatus?.ChunkAttackSeconds ?? 0)</p>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-header bg-light">
                    <strong>Execution Status</strong>
                </div>
                <div class="card-body">
                    <p><strong>Status:</strong> <span class="badge @GetStatusBadgeClass(_jobStatus?.Status ?? _dbJob?.Status)">@(_jobStatus?.Status ?? _dbJob?.Status ?? "Unknown")</span></p>
                    <p><strong>Progress:</strong> @((_jobStatus?.ProgressPercentage ?? _dbJob?.ProgressPercentage ?? 0).ToString("F2")) %</p>
                    
                    @if ((_jobStatus?.Status ?? _dbJob?.Status) is "Running" or "In Progress")
                    {
                        <div class="progress mb-3" style="height: 10px;">
                            <div class="progress-bar progress-bar-striped progress-bar-animated" 
                                 role="progressbar" 
                                 style="width: @Math.Round(_jobStatus?.ProgressPercentage ?? _dbJob?.ProgressPercentage ?? 0)%;"></div>
                        </div>
                        <button class="btn btn-danger btn-sm mt-2" @onclick="CancelJob">Cancel Job</button>
                    }

                    <hr />
                    
                    <h5 class="card-title mb-3" style="cursor: pointer;" @onclick="ToggleAgents">
                        Active agents (@(_jobStatus?.Agents.Count ?? 0))
                        @if (_jobStatus is { Agents: { Count: > 0 } })
                        {
                            <span class="float-end fs-6">@(_isAgentsExpanded ? "▼" : "▶")</span>
                        }
                    </h5>
                    @if (_isAgentsExpanded && _jobStatus is { Agents: { Count: > 0 } })
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Agent</th>
                                        <th>Hashrate</th>
                                        <th>Temp</th>
                                        <th>Fan</th>
                                        <th>GPU</th>
                                        <th>Reject</th>
                                    </tr>
                                </thead>
                                @foreach (var agentStatus in _jobStatus.Agents)
                                {
                                <tbody class="agent-block" style="--agent-bg:@GetAgentColor(agentStatus.Telemetry.AgentId.Id); border-left:4px solid @GetAgentAccentColor(agentStatus.Telemetry.AgentId.Id);">
                                    <tr>
                                        <td class="font-monospace small align-middle" rowspan="@GetAgentRowspan(agentStatus.AssignedChunks)">
                                            @agentStatus.Telemetry.AgentId.Address/@agentStatus.Telemetry.AgentId.Id
                                        </td>
                                        @if (!float.IsNaN(agentStatus.Telemetry.RejectRate))
                                        {
                                            <td class="align-middle">
                                                @agentStatus.Telemetry.CurrentHashrate.ToString("N0") H/s
                                            </td>
                                            <td class="align-middle">
                                                @agentStatus.Telemetry.Temperature °C
                                            </td>
                                            <td class="align-middle">
                                                @agentStatus.Telemetry.FanSpeed %
                                            </td>
                                            <td class="align-middle">
                                                @agentStatus.Telemetry.GpuUtilization %
                                            </td>
                                            <td class="align-middle">
                                                @(agentStatus.Telemetry.RejectRate * 100) %
                                            </td>
                                        }
                                        else
                                        {
                                            <td colspan="5" class="text-muted text-center align-middle">
                                                Waiting for telemetry...
                                            </td>
                                        }
                                    </tr>
                                    @foreach (var chunk in agentStatus.AssignedChunks)
                                    {
                                        @switch (_jobSpecs)
                                        {
                                        case { PayloadCase: JobSpecsEnvelope.PayloadOneofCase.DictionaryJobSpecs }:
                                            <tr class="assignment-row">
                                                <td colspan="2">
                                                    <span class="badge rounded-pill bg-primary text-white me-2">Dictionary</span>
                                                    <br>
                                                    <span class="badge rounded-pill bg-light text-dark">@chunk.WordlistName</span>
                                                </td>
                                                <td colspan="2">
                                                    <span class="badge rounded-pill bg-info text-dark me-2">Bytes</span>
                                                    <br>
                                                    <span class="badge rounded-pill bg-light text-dark">@chunk.ByteStart - @(chunk.ByteEnd == -1 ? "EOF" : chunk.ByteEnd.ToString())</span>
                                                </td>
                                                <td>
                                                    <span class="badge rounded-pill bg-warning text-dark me-2">Size</span>
                                                    <br>
                                                    <span class="badge rounded-pill bg-light text-dark">@GetWordlistSizeLabel(chunk.WordlistName)</span>
                                                </td>
                                            </tr>
                                            break;

                                        case { PayloadCase: JobSpecsEnvelope.PayloadOneofCase.MaskJobSpecs }:
                                            <tr class="assignment-row">
                                                <td colspan="2">
                                                    <span class="badge rounded-pill bg-success text-white me-2">Mask</span>
                                                    <br>
                                                    <span class="badge rounded-pill bg-light text-dark font-monospace">@chunk.Mask</span>
                                                </td>
                                                <td colspan="2">
                                                    <span class="badge rounded-pill bg-info text-dark me-2">Range</span>
                                                    <br>
                                                    <span class="badge rounded-pill bg-light text-dark">@chunk.KeyspaceStart.ToString("N0") - @chunk.KeyspaceEnd.ToString("N0")</span>
                                                </td>
                                                <td>
                                                    <span class="badge rounded-pill bg-warning text-dark me-2">Total</span>
                                                    <br>
                                                    <span class="badge rounded-pill bg-light text-dark">@FormatMaskKeyspace(chunk.TotalKeyspace)</span>
                                                </td>
                                            </tr>
                                            break;
                                        }
                                    }
                                </tbody>
                                }
                            </table>
                        </div>
                    }
                    
                    <hr />
                    
                    <h5 class="card-title mb-3" style="cursor: pointer;" @onclick="ToggleRecoveredPasswords">
                        Recovered passwords (@(_jobStatus?.RecoveredPasswords.Count ?? 0))
                        @if (_jobStatus is { RecoveredPasswords: { Count: > 0 } })
                        {
                            <span class="float-end fs-6">@(_isRecoveredPasswordsExpanded ? "▼" : "▶")</span>
                        }
                    </h5>
                    @if (_isRecoveredPasswordsExpanded && _jobStatus is { RecoveredPasswords: { Count: > 0 } })
                    {
                        <ul class="list-group list-group-flush mb-0">
                            @foreach (var rec in _jobStatus.RecoveredPasswords)
                            {
                                <li class="list-group-item text-break px-0">
                                    <span class="text-muted small">@rec.Hash</span><br/>
                                    <strong>@rec.Plaintext</strong>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public string JobId { get; set; } = "";

    private bool _isLoading = true;
    private JobRecordEntity? _dbJob;
    private JobStatus? _jobStatus;
    private JobSpecsEnvelope? _jobSpecs;
    private List<string> _hashes = [];
    private List<string> _rules = [];

    private readonly CancellationTokenSource _cts = new();
    private bool _isAgentsExpanded = true;
    private bool _isRecoveredPasswordsExpanded = true;
    private bool _isHashesExpanded;
    private bool _isRulesExpanded;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        _isLoading = false;

        _ = Task.Run(async () =>
        {
            try
            {
                using var timer = new PeriodicTimer(TimeSpan.FromSeconds(5));
                while (await timer.WaitForNextTickAsync(_cts.Token))
                {
                    var status = _dbJob?.Status ?? _jobStatus?.Status;
                    if (status is "Running" or "In Progress" or "Initializing")
                    {
                        await InvokeAsync(LoadData);
                        await InvokeAsync(StateHasChanged);
                    }
                }
            }
            catch (OperationCanceledException) { }
        });
    }

    private async Task LoadData()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            _dbJob = await db.JobRecords.AsNoTracking().FirstOrDefaultAsync(j => j.JobId == JobId);

            // Fetch real-time status from Orleans if available
            var jobCoordinator = ActorSystem.Cluster().GetJobCoordinatorGrain(JobId);
            _jobStatus = await jobCoordinator.GetJobStatus(CancellationToken.None);

            // Fetch specs based on mode
            var mode = _dbJob?.AttackMode;
            _jobSpecs = await jobCoordinator.GetJobSpecs(CancellationToken.None);
            _hashes = _jobSpecs?.Hashes.ToList() ?? [];
            _rules = GetRulesFromSpecs(_jobSpecs).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading job details: {ex.Message}");
        }
    }

    private async Task CancelJob()
    {
        var jobManager = ActorSystem.Cluster().GetJobManagerGrain("root");
        await jobManager.CancelJob(new JobId { Id = JobId }, CancellationToken.None);
        await LoadData();
    }

    private void ToggleAgents() => _isAgentsExpanded = !_isAgentsExpanded;
    private void ToggleRecoveredPasswords() => _isRecoveredPasswordsExpanded = !_isRecoveredPasswordsExpanded;
    private void ToggleHashes() => _isHashesExpanded = !_isHashesExpanded;
    private void ToggleRules() => _isRulesExpanded = !_isRulesExpanded;

    private string GetStatusBadgeClass(string? status) => status switch
    {
        "Completed" => "bg-success",
        "Running" or "In Progress" => "bg-primary",
        "Cancelled" => "bg-danger",
        "Initializing" => "bg-secondary",
        _ => "bg-dark"
    };

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }

    private string GetAgentColor(string id)
    {
        // deterministic hash to H (0..360)
        var h = Math.Abs(id.GetHashCode()) % 360;
        return $"hsl({h}, 70%, 95%)";
    }

    private string GetAgentAccentColor(string id)
    {
        var h = Math.Abs(id.GetHashCode()) % 360;
        return $"hsl({h}, 70%, 45%)";
    }

    private int GetAgentRowspan(IList<AssignedChunk> chunks) => 1 + chunks.Count;

    private string GetWordlistSizeLabel(string? wordlistName)
    {
        if (string.IsNullOrWhiteSpace(wordlistName))
        {
            return "Unknown";
        }

        try
        {
            var size = WordlistService.GetWordlistFileSize(wordlistName);
            return FormatBytes(size);
        }
        catch
        {
            return "Unavailable";
        }
    }

    private string FormatMaskKeyspace(ulong keyspace)
    {
        return keyspace == 0 ? "Unknown" : keyspace.ToString("N0");
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes < 0)
        {
            return "Unknown";
        }

        if (bytes < 1024)
        {
            return $"{bytes} B";
        }

        var value = (double)bytes;
        if (bytes < 1024 * 1024)
        {
            return $"{value / 1024.0:F1} KiB";
        }

        if (bytes < 1024L * 1024L * 1024L)
        {
            return $"{value / (1024.0 * 1024.0):F1} MiB";
        }

        return $"{value / (1024.0 * 1024.0 * 1024.0):F1} GiB";
    }

    private static IEnumerable<string> GetRulesFromSpecs(JobSpecsEnvelope? specs)
    {
        if (specs is null)
        {
            return [];
        }

        var ruleContent = specs.PayloadCase switch
        {
            JobSpecsEnvelope.PayloadOneofCase.DictionaryJobSpecs => specs.DictionaryJobSpecs.RuleFileContent,
            JobSpecsEnvelope.PayloadOneofCase.CombinatorJobSpecs => specs.CombinatorJobSpecs.RuleFileContent,
            _ => string.Empty
        };

        return string.IsNullOrWhiteSpace(ruleContent)
            ? []
            : ruleContent.Split(['\r', '\n'], StringSplitOptions.RemoveEmptyEntries)
                .Select(rule => rule.Trim())
                .Where(rule => !string.IsNullOrWhiteSpace(rule));
    }
}