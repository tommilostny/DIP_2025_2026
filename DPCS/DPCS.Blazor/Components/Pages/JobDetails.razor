@page "/job-details/{*JobId}"
@rendermode InteractiveServer
@using DPCS.DAL
@using DPCS.DAL.Entities
@using DPCS.Shared
@using Microsoft.EntityFrameworkCore
@inject ActorSystem ActorSystem
@inject IDbContextFactory<DpcsDbContext> DbFactory
@inject WordlistService WordlistService
@implements IDisposable

<PageTitle>Job Details</PageTitle>

<div class="mb-4">
    @if (_jobStatus is not null)
    {
        <a href="/" class="text-decoration-none">&larr; Back to Dashboard</a>
    }
    else
    {
        @if (_dbJob is not null)
        {
            <a href="job-history" class="text-decoration-none">&larr; Back to History</a>
        }
    }
</div>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1>Job Details</h1>
        <h5 class="text-muted font-monospace mb-0">@JobId</h5>
    </div>
    <button class="btn btn-outline-secondary" @onclick="LoadData">Refresh</button>
</div>

@if (_isLoading)
{
    <div class="spinner-border" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
}
else if (_dbJob is null && _jobStatus is null)
{
    <div class="alert alert-warning">Job not found.</div>
}
else
{
    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-header bg-light">
                    <strong>Configuration</strong>
                </div>
                <div class="card-body">
                    <p>
                        <strong>Attack mode:</strong> @(_dbJob?.AttackMode ?? 0) 
                        (@(((AttackMode)(_dbJob?.AttackMode ?? 0)).ToString()))
                    </p>

                    @switch (_jobSpecs)
                    {
                    case { PayloadCase: JobSpecsEnvelope.PayloadOneofCase.MaskJobSpecs }:
                        <p><strong>Masks: </strong></p>
                        <ul>
                            @foreach (var mask in _jobSpecs.MaskJobSpecs.Masks)
                            {
                                <li class="font-monospace">@mask</li>
                            }
                        </ul>
                        @if (!string.IsNullOrWhiteSpace(_jobSpecs.MaskJobSpecs.CustomCharset1))
                        {
                            <p class="mb-1"><strong>Charset 1 (?1): </strong> @_jobSpecs.MaskJobSpecs.CustomCharset1</p>
                        }
                        @if (!string.IsNullOrWhiteSpace(_jobSpecs.MaskJobSpecs.CustomCharset2))
                        {
                            <p class="mb-1"><strong>Charset 2 (?2): </strong> @_jobSpecs.MaskJobSpecs.CustomCharset2</p>
                        }
                        @if (!string.IsNullOrWhiteSpace(_jobSpecs.MaskJobSpecs.CustomCharset3))
                        {
                            <p class="mb-1"><strong>Charset 3 (?3): </strong> @_jobSpecs.MaskJobSpecs.CustomCharset3</p>
                        }
                        @if (!string.IsNullOrWhiteSpace(_jobSpecs.MaskJobSpecs.CustomCharset4))
                        {
                            <p class="mb-1"><strong>Charset 4 (?4): </strong> @_jobSpecs.MaskJobSpecs.CustomCharset4</p>
                        }
                        break;

                    case { PayloadCase: JobSpecsEnvelope.PayloadOneofCase.DictionaryJobSpecs }:
                        <strong>Wordlists:</strong>
                        <ul>
                            @foreach (var wordlist in _jobSpecs.DictionaryJobSpecs.Wordlists)
                            {
                                <li>@wordlist</li>
                            }
                        </ul>
                        break;
                    }

                    <p class="mt-3">
                        <strong>Hash type:</strong> @(_dbJob?.HashType ?? 0) (@HashTypeMap.GetHashTypeName(_dbJob?.HashType ?? 0))
                    </p>

                    <strong style="cursor: pointer;" @onclick="ToggleHashes" class="d-block mb-2">
                        Hashes (@(_hashes.Count))
                        <span class="float-end">@(_isHashesExpanded ? "▼" : "▶")</span>
                    </strong>
                    @if (_isHashesExpanded && _hashes.Count > 0)
                    {
                        <div class="bg-light p-2 rounded" style="max-height: 200px; overflow-y: auto;">
                            <ul class="mb-0 font-monospace small" style="word-break: break-all;">
                                @foreach (var hash in _hashes)
                                {
                                    <li>@hash</li>
                                }
                            </ul>
                        </div>
                    }

                    @if (_rules.Count > 0)
                    {
                        <strong style="cursor: pointer;" @onclick="ToggleRules" class="d-block mt-3 mb-2">
                            Rules (@_rules.Count)
                            <span class="float-end">@(_isRulesExpanded ? "▼" : "▶")</span>
                        </strong>
                        @if (_isRulesExpanded)
                        {
                            <div class="bg-light p-2 rounded" style="max-height: 200px; overflow-y: auto;">
                                <ul class="mb-0 font-monospace small" style="word-break: break-all;">
                                    @foreach (var rule in _rules)
                                    {
                                        <li>@rule</li>
                                    }
                                </ul>
                            </div>
                        }
                    }

                    <p class="mt-3 mb-0"><strong>Chunk Attack seconds:</strong> @(_jobStatus?.ChunkAttackSeconds ?? 0)</p>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-header bg-light">
                    <strong>Execution Status</strong>
                </div>
                <div class="card-body">
                    <p><strong>Status:</strong> <span class="badge @GetStatusBadgeClass(_jobStatus?.Status ?? _dbJob?.Status)">@(_jobStatus?.Status ?? _dbJob?.Status ?? "Unknown")</span></p>
                    <p><strong>Progress:</strong> @((_jobStatus?.ProgressPercentage ?? _dbJob?.ProgressPercentage ?? 0).ToString("F2")) %</p>
                    
                    @if ((_jobStatus?.Status ?? _dbJob?.Status) is "Running" or "In Progress")
                    {
                        <div class="progress mb-3" style="height: 10px;">
                            <div class="progress-bar progress-bar-striped progress-bar-animated" 
                                 role="progressbar" 
                                 style="width: @Math.Round(_jobStatus?.ProgressPercentage ?? _dbJob?.ProgressPercentage ?? 0)%;"></div>
                        </div>
                        <button class="btn btn-danger btn-sm mt-2" @onclick="CancelJob">Cancel Job</button>
                    }

                    <hr />
                    
                    <h5 class="card-title mb-3" style="cursor: pointer;" @onclick="ToggleAgents">
                        Active agents (@(_jobStatus?.Agents.Count ?? 0))
                        @if (_jobStatus is { Agents: { Count: > 0 } })
                        {
                            <span class="float-end fs-6">@(_isAgentsExpanded ? "▼" : "▶")</span>
                        }
                    </h5>
                    @if (_isAgentsExpanded && _jobStatus is { Agents: { Count: > 0 } })
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Agent</th>
                                        <th>Hashrate</th>
                                        <th>Temp</th>
                                        <th>Fan</th>
                                        <th>GPU Util</th>
                                        <th>Reject</th>
                                    </tr>
                                </thead>
                                @foreach (var agentStatus in _jobStatus.Agents)
                                {
                                <tbody class="agent-block" style="--agent-bg:@GetAgentColor(agentStatus.Telemetry.AgentId.Id); border-left:4px solid @GetAgentAccentColor(agentStatus.Telemetry.AgentId.Id);">
                                    <tr>
                                        <td class="font-monospace small align-middle" rowspan="@GetAgentRowspan(agentStatus)">
                                            @agentStatus.Telemetry.AgentId.Address/@agentStatus.Telemetry.AgentId.Id
                                        </td>
                                        @if (!float.IsNaN(agentStatus.Telemetry.RejectRate))
                                        {
                                            <td class="align-middle">
                                                @agentStatus.Telemetry.CurrentHashrate.ToString("N0") H/s
                                            </td>
                                            <td class="align-middle">
                                                @agentStatus.Telemetry.Temperature °C
                                            </td>
                                            <td class="align-middle">
                                                @agentStatus.Telemetry.FanSpeed %
                                            </td>
                                            <td class="align-middle">
                                                @agentStatus.Telemetry.GpuUtilization %
                                            </td>
                                            <td class="align-middle">
                                                @(agentStatus.Telemetry.RejectRate * 100) %
                                            </td>
                                        }
                                        else
                                        {
                                            <td colspan="5" class="text-muted text-center align-middle">
                                                Waiting for telemetry...
                                            </td>
                                        }
                                    </tr>
                                    @foreach (var gpu in agentStatus.Telemetry.GpuDevices.OrderBy(g => g.DeviceIndex))
                                    {
                                        <tr class="assignment-row">
                                            <td colspan="5">
                                                <span class="badge rounded-pill bg-dark text-white me-2">GPU @gpu.DeviceIndex</span>
                                                @if (!string.IsNullOrWhiteSpace(gpu.DeviceName))
                                                {
                                                    <span class="badge rounded-pill bg-secondary me-2">@gpu.DeviceName</span>
                                                }
                                                <span class="badge rounded-pill bg-light text-dark me-2">Hashrate: @FormatGpuHashrate(gpu.CurrentHashrate)</span>
                                                <span class="badge rounded-pill bg-light text-dark me-2">Temp: @FormatIntMetric(gpu.Temperature, "°C")</span>
                                                <span class="badge rounded-pill bg-light text-dark me-2">Fan: @FormatIntMetric(gpu.FanSpeed, "%")</span>
                                                <span class="badge rounded-pill bg-light text-dark me-2">GPU Util: @FormatIntMetric(gpu.GpuUtilization, "%")</span>
                                                <span class="badge rounded-pill bg-light text-dark me-2">VRAM: @FormatVramMetric(gpu.VramUsedBytes, gpu.VramTotalBytes, gpu.VramUtilization)</span>
                                            </td>
                                        </tr>
                                    }
                                    @foreach (var chunk in agentStatus.AssignedChunks)
                                    {
                                        @switch (chunk.PayloadCase)
                                        {
                                        case AssignedChunk.PayloadOneofCase.DictionaryChunk:
                                            <tr class="assignment-row">
                                                <td colspan="2">
                                                    <span class="badge rounded-pill bg-primary text-white me-2">Dictionary</span>
                                                    <br>
                                                    <span class="badge rounded-pill bg-light text-dark">@chunk.DictionaryChunk.WordlistName</span>
                                                </td>
                                                <td colspan="2">
                                                    <span class="badge rounded-pill bg-info text-dark me-2">Bytes</span>
                                                    <br>
                                                    <span class="badge rounded-pill bg-light text-dark">@chunk.DictionaryChunk.ByteStart - @(chunk.DictionaryChunk.ByteEnd == -1 ? "EOF" : chunk.DictionaryChunk.ByteEnd.ToString())</span>
                                                </td>
                                                <td>
                                                    <span class="badge rounded-pill bg-warning text-dark me-2">Size</span>
                                                    <br>
                                                    <span class="badge rounded-pill bg-light text-dark">@GetWordlistSizeLabel(chunk.DictionaryChunk.WordlistName)</span>
                                                </td>
                                            </tr>
                                            break;

                                        case AssignedChunk.PayloadOneofCase.MaskChunk:
                                            <tr class="assignment-row">
                                                <td colspan="2">
                                                    <span class="badge rounded-pill bg-success text-white me-2">Mask</span>
                                                    <br>
                                                    <span class="badge rounded-pill bg-light text-dark font-monospace">@chunk.MaskChunk.Mask</span>
                                                </td>
                                                <td colspan="2">
                                                    <span class="badge rounded-pill bg-info text-dark me-2">Range</span>
                                                    <br>
                                                    <span class="badge rounded-pill bg-light text-dark">@chunk.MaskChunk.KeyspaceStart.ToString("N0") - @chunk.MaskChunk.KeyspaceEnd.ToString("N0")</span>
                                                </td>
                                                <td>
                                                    <span class="badge rounded-pill bg-warning text-dark me-2">Total</span>
                                                    <br>
                                                    <span class="badge rounded-pill bg-light text-dark">@FormatMaskKeyspace(chunk.MaskChunk.TotalKeyspace)</span>
                                                </td>
                                            </tr>
                                            break;

                                        case AssignedChunk.PayloadOneofCase.CombinatorChunk:
                                            <tr class="assignment-row">
                                                <td colspan="2">
                                                    <span class="badge rounded-pill bg-primary text-white me-2">Left</span>
                                                    <br>
                                                    <span class="badge rounded-pill bg-light text-dark">@chunk.CombinatorChunk.LeftWordlistName</span>
                                                </td>
                                                <td colspan="2">
                                                    <span class="badge rounded-pill bg-info text-dark me-2">Left Bytes</span>
                                                    <br>
                                                    <span class="badge rounded-pill bg-light text-dark">@chunk.CombinatorChunk.LeftByteStart - @(chunk.CombinatorChunk.LeftByteEnd == -1 ? "EOF" : chunk.CombinatorChunk.LeftByteEnd.ToString())</span>
                                                </td>
                                                <td>
                                                    <span class="badge rounded-pill bg-warning text-dark me-2">Left Size</span>
                                                    <br>
                                                    <span class="badge rounded-pill bg-light text-dark">@GetWordlistSizeLabel(chunk.CombinatorChunk.LeftWordlistName)</span>
                                                </td>
                                            </tr>
                                            <tr class="assignment-row">
                                                <td colspan="2">
                                                    <span class="badge rounded-pill bg-secondary text-white me-2">Right</span>
                                                    <br>
                                                    <span class="badge rounded-pill bg-light text-dark">@chunk.CombinatorChunk.RightWordlistName</span>
                                                </td>
                                                <td colspan="2">
                                                    <span class="badge rounded-pill bg-info text-dark me-2">Right Bytes</span>
                                                    <br>
                                                    <span class="badge rounded-pill bg-light text-dark">@chunk.CombinatorChunk.RightByteStart - @(chunk.CombinatorChunk.RightByteEnd == -1 ? "EOF" : chunk.CombinatorChunk.RightByteEnd.ToString())</span>
                                                </td>
                                                <td>
                                                    <span class="badge rounded-pill bg-warning text-dark me-2">Right Size</span>
                                                    <br>
                                                    <span class="badge rounded-pill bg-light text-dark">@GetWordlistSizeLabel(chunk.CombinatorChunk.RightWordlistName)</span>
                                                </td>
                                            </tr>
                                            break;
                                        }
                                    }
                                </tbody>
                                }
                            </table>
                        </div>
                    }
                    
                    <hr />
                    
                    <h5 class="card-title mb-3" style="cursor: pointer;" @onclick="ToggleRecoveredPasswords">
                        Recovered passwords (@(_jobStatus?.RecoveredPasswords.Count ?? 0))
                        @if (_jobStatus is { RecoveredPasswords: { Count: > 0 } })
                        {
                            <span class="float-end fs-6">@(_isRecoveredPasswordsExpanded ? "▼" : "▶")</span>
                        }
                    </h5>
                    @if (_isRecoveredPasswordsExpanded && _jobStatus is { RecoveredPasswords: { Count: > 0 } })
                    {
                        <ul class="list-group list-group-flush mb-0">
                            @foreach (var rec in _jobStatus.RecoveredPasswords)
                            {
                                <li class="list-group-item text-break px-0">
                                    <span class="text-muted small">@rec.Hash</span><br/>
                                    <strong>@rec.Plaintext</strong>
                                </li>
                            }
                        </ul>
                    }

                </div>
            </div>
        </div>
    </div>

    @if (_attackReport is { TotalWorkUnits: > 0 })
    {
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-light d-flex justify-content-between align-items-center">
                <strong>Attack Report</strong>
                <div class="d-flex gap-2 flex-wrap">
                    <a class="btn btn-outline-primary btn-sm" href="/api/jobs/@JobId/work-units">Export JSON</a>
                    <a class="btn btn-outline-secondary btn-sm" href="/api/jobs/@JobId/work-units?format=csv">Export CSV</a>
                </div>
            </div>
            <div class="card-body">
                <div class="row g-2 mb-3">
                    <div class="col-sm-6 col-lg-3">
                        <div class="border rounded p-2 bg-light">
                            <div class="small text-muted">Total WU</div>
                            <div class="fw-semibold">@_attackReport.TotalWorkUnits</div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-lg-3">
                        <div class="border rounded p-2 bg-light">
                            <div class="small text-muted">Completed WU</div>
                            <div class="fw-semibold">@_attackReport.CompletedWorkUnits (@_attackReport.CompletedRatePercent.ToString("F1")%)</div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-lg-3">
                        <div class="border rounded p-2 bg-light">
                            <div class="small text-muted">Timed Out WU</div>
                            <div class="fw-semibold">@_attackReport.TimedOutWorkUnits (@_attackReport.TimeoutRatePercent.ToString("F1")%)</div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-lg-3">
                        <div class="border rounded p-2 bg-light">
                            <div class="small text-muted">Retry WU</div>
                            <div class="fw-semibold">@_attackReport.RetriedWorkUnits</div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-lg-3">
                        <div class="border rounded p-2 bg-light">
                            <div class="small text-muted">Mean WU Duration</div>
                            <div class="fw-semibold">@FormatDurationSeconds(_attackReport.MeanDurationSeconds)</div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-lg-3">
                        <div class="border rounded p-2 bg-light">
                            <div class="small text-muted">P95 WU Duration</div>
                            <div class="fw-semibold">@FormatDurationSeconds(_attackReport.P95DurationSeconds)</div>
                        </div>
                    </div>
                </div>

                @if (_attackReport.ByAgent.Count > 0)
                {
                    <div class="small text-muted mb-2">
                        Participating agents: @GetParticipatingAgentCount()
                    </div>
                    <div class="table-responsive mb-3">
                        <table class="table table-sm table-bordered mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Agent</th>
                                    <th>Total WU</th>
                                    <th>Completed</th>
                                    <th>Timed Out</th>
                                    <th>Mean Duration</th>
                                    <th>Avg Hashrate</th>
                                    <th>Avg Temp</th>
                                    <th>Avg Fan</th>
                                    <th>Avg GPU Util</th>
                                    <th>Avg VRAM Util</th>
                                    <th>Avg VRAM Used / Total</th>
                                    <th>Reject</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in _attackReport.ByAgent.OrderByDescending(x => x.TotalWorkUnits))
                                {
                                    var agentStatusReport = GetAgentStatusForReport(item.AgentKey);
                                    <tr>
                                        <td class="font-monospace small" rowspan="@GetReportAgentRowspan(agentStatusReport)">@item.AgentKey</td>
                                        <td>@item.TotalWorkUnits</td>
                                        <td>@item.CompletedWorkUnits</td>
                                        <td>@item.TimedOutWorkUnits</td>
                                        <td>@FormatDurationSeconds(item.MeanDurationSeconds)</td>
                                        <td>@FormatGpuHashrate(agentStatusReport?.Telemetry.CurrentHashrate ?? -1)</td>
                                        <td>@FormatIntMetric(agentStatusReport?.Telemetry.Temperature ?? -1, "°C")</td>
                                        <td>@FormatIntMetric(agentStatusReport?.Telemetry.FanSpeed ?? -1, "%")</td>
                                        <td>@FormatIntMetric(agentStatusReport?.Telemetry.GpuUtilization ?? -1, "%")</td>
                                        <td>@FormatAverageGpuUtilization(agentStatusReport?.Telemetry.GpuDevices)</td>
                                        <td>@FormatAverageVramUsage(agentStatusReport?.Telemetry.GpuDevices)</td>
                                        <td>@FormatRejectRate(agentStatusReport?.Telemetry.RejectRate)</td>
                                    </tr>

                                    @if (agentStatusReport is not null && agentStatusReport.Telemetry.GpuDevices.Count > 0)
                                    {
                                        @foreach (var gpu in agentStatusReport.Telemetry.GpuDevices.OrderBy(g => g.DeviceIndex))
                                        {
                                            <tr class="assignment-row">
                                                <td colspan="4">
                                                    <span class="badge rounded-pill bg-dark text-white me-2">GPU @gpu.DeviceIndex</span>
                                                    @if (!string.IsNullOrWhiteSpace(gpu.DeviceName))
                                                    {
                                                        <span class="badge rounded-pill bg-secondary">@gpu.DeviceName</span>
                                                    }
                                                </td>
                                                <td>@FormatGpuHashrate(gpu.CurrentHashrate)</td>
                                                <td>@FormatIntMetric(gpu.Temperature, "°C")</td>
                                                <td>@FormatIntMetric(gpu.FanSpeed, "%")</td>
                                                <td>@FormatIntMetric(gpu.GpuUtilization, "%")</td>
                                                <td>@FormatIntMetric(gpu.VramUtilization, "%")</td>
                                                <td>@FormatVramMetric(gpu.VramUsedBytes, gpu.VramTotalBytes, gpu.VramUtilization)</td>
                                                <td class="text-muted">-</td>
                                            </tr>
                                        }
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @if (_attackReport.Chunks.Count > 0)
                {
                    <div class="d-flex justify-content-between align-items-center mb-2 mt-3">
                        <div>
                            <strong>Chunk Details</strong>
                            <span class="text-muted small ms-2">@_attackReport.Chunks.Count unique chunks, @_attackReport.Chunks.Sum(c => c.AttemptCount) attempts</span>
                        </div>
                        <div class="d-flex gap-2 align-items-center">
                            @if (_isChunkDetailsExpanded)
                            {
                                <span class="small text-muted">Showing @GetChunkRangeLabel()</span>
                            }
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ToggleChunkDetails">
                                @(_isChunkDetailsExpanded ? "Hide" : "Show")
                            </button>
                        </div>
                    </div>

                    @if (_isChunkDetailsExpanded)
                    {
                        <div class="table-responsive mb-3">
                            <table class="table table-sm table-bordered align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Chunk</th>
                                        <th>Mode</th>
                                        <th>Attempts</th>
                                        <th>Agents</th>
                                        <th>Final Outcome</th>
                                        <th>Mean Duration</th>
                                        <th>Recovered</th>
                                        <th>Attempt History</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var chunk in GetVisibleChunks())
                                    {
                                        <tr>
                                            <td>
                                                <div class="small fw-semibold">@chunk.Display.Title</div>
                                                @if (!string.IsNullOrWhiteSpace(chunk.Display.PrimaryRange))
                                                {
                                                    <div class="small text-muted">@chunk.Display.PrimaryRange</div>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(chunk.Display.SecondaryTitle))
                                                {
                                                    <div class="small fw-semibold mt-2">@chunk.Display.SecondaryTitle</div>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(chunk.Display.SecondaryRange))
                                                {
                                                    <div class="small text-muted">@chunk.Display.SecondaryRange</div>
                                                }
                                            </td>
                                            <td>@chunk.Mode</td>
                                            <td>@chunk.AttemptCount</td>
                                            <td>
                                                @foreach (var agent in chunk.Agents)
                                                {
                                                    <div class="font-monospace small">@agent</div>
                                                }
                                            </td>
                                            <td>
                                                <span class="badge @GetOutcomeBadgeClass(chunk.FinalOutcome)">@FormatOutcome(chunk.FinalOutcome)</span>
                                            </td>
                                            <td>@FormatDurationSeconds(chunk.MeanDurationSeconds)</td>
                                            <td>@chunk.RecoveredCount</td>
                                            <td>
                                                @foreach (var attempt in chunk.Attempts)
                                                {
                                                    <div class="border rounded p-1 mb-1 bg-light-subtle">
                                                        <div class="font-monospace small">@attempt.RequestId</div>
                                                        <div class="small">@attempt.AgentKey</div>
                                                        <div class="small text-muted">Assigned: @attempt.AssignedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</div>
                                                        <div class="small">
                                                            <span class="badge @GetOutcomeBadgeClass(attempt.Outcome)">@FormatOutcome(attempt.Outcome)</span>
                                                            <span class="ms-2">@FormatDurationSeconds(attempt.ProcessingDurationSeconds)</span>
                                                            @if (attempt.RecoveredCount > 0)
                                                            {
                                                                <span class="ms-2">Recovered: @attempt.RecoveredCount</span>
                                                            }
                                                        </div>
                                                    </div>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        @if (GetChunkPageCount() > 1)
                        {
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div class="small text-muted">Page @_chunkDetailsPage of @GetChunkPageCount()</div>
                                <div class="btn-group" role="group" aria-label="Chunk details pagination">
                                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ShowPreviousChunkPage" disabled="@(_chunkDetailsPage <= 1)">Previous 10</button>
                                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ShowNextChunkPage" disabled="@(_chunkDetailsPage >= GetChunkPageCount())">Next 10</button>
                                </div>
                            </div>
                        }
                    }
                }

