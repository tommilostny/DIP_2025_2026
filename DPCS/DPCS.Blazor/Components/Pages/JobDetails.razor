@page "/job-details/{*JobId}"
@rendermode InteractiveServer
@using DPCS.DAL
@using DPCS.DAL.Entities
@using DPCS.Shared
@using Microsoft.EntityFrameworkCore
@inject ActorSystem ActorSystem
@inject IDbContextFactory<DpcsDbContext> DbFactory
@implements IDisposable

<PageTitle>Job Details</PageTitle>

<div class="mb-4">
    @if (_jobStatus is not null)
    {
        <a href="/" class="text-decoration-none">&larr; Back to Dashboard</a>
    }
    else
    {
        @if (_dbJob is not null)
        {
            <a href="job-history" class="text-decoration-none">&larr; Back to History</a>
        }
    }
</div>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1>Job Details</h1>
        <h5 class="text-muted font-monospace mb-0">@JobId</h5>
    </div>
    <button class="btn btn-outline-secondary" @onclick="LoadData">Refresh</button>
</div>

@if (_isLoading)
{
    <div class="spinner-border" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
}
else if (_dbJob is null && _jobStatus is null)
{
    <div class="alert alert-warning">Job not found.</div>
}
else
{
    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-header bg-light">
                    <strong>Configuration</strong>
                </div>
                <div class="card-body">
                    <p>
                        <strong>Attack mode:</strong> @(_dbJob?.AttackMode ?? 0) 
                        (@(((AttackMode)(_dbJob?.AttackMode ?? 0)).ToString()))
                    </p>

                    @switch (_jobSpecs)
                    {
                    case { PayloadCase: JobSpecsEnvelope.PayloadOneofCase.MaskJobSpecs }:
                        <p><strong>Masks: </strong></p>
                        <ul>
                            @foreach (var mask in _jobSpecs.MaskJobSpecs.Masks)
                            {
                                <li class="font-monospace">@mask</li>
                            }
                        </ul>
                        <CustomCharsetFields ReadOnly="true"
                                             Charset1="@_jobSpecs.MaskJobSpecs.CustomCharset1"
                                             Charset2="@_jobSpecs.MaskJobSpecs.CustomCharset2"
                                             Charset3="@_jobSpecs.MaskJobSpecs.CustomCharset3"
                                             Charset4="@_jobSpecs.MaskJobSpecs.CustomCharset4" />
                        break;

                    case { PayloadCase: JobSpecsEnvelope.PayloadOneofCase.DictionaryJobSpecs }:
                        <strong>Wordlists:</strong>
                        <ul>
                            @foreach (var wordlist in _jobSpecs.DictionaryJobSpecs.Wordlists)
                            {
                                <li>@wordlist</li>
                            }
                        </ul>
                        break;

                    case { PayloadCase: JobSpecsEnvelope.PayloadOneofCase.HybridJobSpecs }:
                        <strong>Wordlists:</strong>
                        <ul>
                            @foreach (var wordlist in _jobSpecs.HybridJobSpecs.Wordlists)
                            {
                                <li>@wordlist</li>
                            }
                        </ul>
                        <p><strong>Masks:</strong></p>
                        <ul>
                            @foreach (var mask in _jobSpecs.HybridJobSpecs.Masks)
                            {
                                <li class="font-monospace">@mask</li>
                            }
                        </ul>
                        <CustomCharsetFields ReadOnly="true"
                                             Charset1="@_jobSpecs.HybridJobSpecs.CustomCharset1"
                                             Charset2="@_jobSpecs.HybridJobSpecs.CustomCharset2"
                                             Charset3="@_jobSpecs.HybridJobSpecs.CustomCharset3"
                                             Charset4="@_jobSpecs.HybridJobSpecs.CustomCharset4" />
                        break;
                    }

                    <p class="mt-3">
                        <strong>Hash type:</strong> @(_dbJob?.HashType ?? 0) (@HashTypeMap.GetHashTypeName(_dbJob?.HashType ?? 0))
                    </p>

                    <strong style="cursor: pointer;" @onclick="ToggleHashes" class="d-block mb-2">
                        Hashes (@(_hashes.Count))
                        <span class="float-end">@(_isHashesExpanded ? "▼" : "▶")</span>
                    </strong>
                    @if (_isHashesExpanded && _hashes.Count > 0)
                    {
                        <div class="bg-light p-2 rounded" style="max-height: 200px; overflow-y: auto;">
                            <ul class="mb-0 font-monospace small" style="word-break: break-all;">
                                @foreach (var hash in _hashes)
                                {
                                    <li>@hash</li>
                                }
                            </ul>
                        </div>
                    }

                    @if (_rules.Count > 0)
                    {
                        <strong style="cursor: pointer;" @onclick="ToggleRules" class="d-block mt-3 mb-2">
                            Rules (@_rules.Count)
                            <span class="float-end">@(_isRulesExpanded ? "▼" : "▶")</span>
                        </strong>
                        @if (_isRulesExpanded)
                        {
                            <div class="bg-light p-2 rounded" style="max-height: 200px; overflow-y: auto;">
                                <ul class="mb-0 font-monospace small" style="word-break: break-all;">
                                    @foreach (var rule in _rules)
                                    {
                                        <li>@rule</li>
                                    }
                                </ul>
                            </div>
                        }
                    }

                    <p class="mt-3 mb-0"><strong>Chunk Attack seconds:</strong> @(_jobStatus?.ChunkAttackSeconds ?? 0)</p>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-header bg-light">
                    <strong>Execution Status</strong>
                </div>
                <div class="card-body">
                    <p><strong>Status:</strong> <span class="badge @GetStatusBadgeClass(_jobStatus?.Status ?? _dbJob?.Status)">@(_jobStatus?.Status ?? _dbJob?.Status ?? "Unknown")</span></p>
                    <p><strong>Progress:</strong> @((_jobStatus?.ProgressPercentage ?? _dbJob?.ProgressPercentage ?? 0).ToString("F2")) %</p>
                    
                    @if ((_jobStatus?.Status ?? _dbJob?.Status) is "Running" or "In Progress")
                    {
                        <div class="progress mb-3" style="height: 10px;">
                            <div class="progress-bar progress-bar-striped progress-bar-animated" 
                                 role="progressbar" 
                                 style="width: @Math.Round(_jobStatus?.ProgressPercentage ?? _dbJob?.ProgressPercentage ?? 0)%;"></div>
                        </div>
                        <button class="btn btn-danger btn-sm mt-2" @onclick="CancelJob">Cancel Job</button>
                    }

                    <ActiveAgentsCard JobStatus="_jobStatus" />
                    
                    <hr />
                    
                    <h5 class="card-title mb-3" style="cursor: pointer;" @onclick="ToggleRecoveredPasswords">
                        Recovered passwords (@(_jobStatus?.RecoveredPasswords.Count ?? 0))
                        @if (_jobStatus is { RecoveredPasswords: { Count: > 0 } })
                        {
                            <span class="float-end fs-6">@(_isRecoveredPasswordsExpanded ? "▼" : "▶")</span>
                        }
                    </h5>
                    @if (_isRecoveredPasswordsExpanded && _jobStatus is { RecoveredPasswords: { Count: > 0 } })
                    {
                        <ul class="list-group list-group-flush mb-0">
                            @foreach (var rec in _jobStatus.RecoveredPasswords)
                            {
                                <li class="list-group-item text-break px-0">
                                    <span class="text-muted small">@rec.Hash</span><br/>
                                    <strong>@rec.Plaintext</strong>
                                </li>
                            }
                        </ul>
                    }

                </div>
            </div>
        </div>
    </div>

    @if (_attackReport is { TotalWorkUnits: > 0 })
    {
        <AttackReportCard JobId="@JobId"
                          AttackReport="_attackReport"
                          JobStatus="_jobStatus"
                          ChartCacheBust="_chartCacheBust" />
    }
}

@code {
    [Parameter]
    public string JobId { get; set; } = "";

    private bool _isLoading = true;
    private JobRecordEntity? _dbJob;
    private JobStatus? _jobStatus;
    private JobSpecsEnvelope? _jobSpecs;
    private WorkUnitLifecycleExport? _workUnitLifecycle;
    private AttackReportSummary? _attackReport;
    private long _chartCacheBust;
    private List<string> _hashes = [];
    private List<string> _rules = [];

    private readonly CancellationTokenSource _cts = new();
    private bool _isRecoveredPasswordsExpanded = true;
    private bool _isHashesExpanded;
    private bool _isRulesExpanded;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        _isLoading = false;

        _ = Task.Run(async () =>
        {
            try
            {
                using var timer = new PeriodicTimer(TimeSpan.FromSeconds(5));
                while (await timer.WaitForNextTickAsync(_cts.Token))
                {
                    var status = _dbJob?.Status ?? _jobStatus?.Status;
                    if (status is "Running" or "In Progress" or "Initializing")
                    {
                        await InvokeAsync(LoadData);
                        await InvokeAsync(StateHasChanged);
                    }
                }
            }
            catch (OperationCanceledException) { }
        });
    }

    private async Task LoadData()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            _dbJob = await db.JobRecords.AsNoTracking().FirstOrDefaultAsync(j => j.JobId == JobId);

            // Fetch real-time status from Orleans if available
            var jobCoordinator = ActorSystem.Cluster().GetJobCoordinatorGrain(JobId);
            _jobStatus = await jobCoordinator.GetJobStatus(CancellationToken.None);

            // Fetch specs based on mode
            var mode = _dbJob?.AttackMode;
            _jobSpecs = await jobCoordinator.GetJobSpecs(CancellationToken.None);
            _hashes = _jobSpecs?.Hashes.ToList() ?? [];
            _rules = GetRulesFromSpecs(_jobSpecs).ToList();

            _workUnitLifecycle = await jobCoordinator.GetWorkUnitLifecycle(new WorkUnitLifecycleFilter(), CancellationToken.None);
            _attackReport = BuildAttackReport(_workUnitLifecycle);
            _chartCacheBust = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading job details: {ex.Message}");
        }
    }

    private async Task CancelJob()
    {
        var jobManager = ActorSystem.Cluster().GetJobManagerGrain("root");
        await jobManager.CancelJob(new JobId { Id = JobId }, CancellationToken.None);
        await LoadData();
    }

    private void ToggleRecoveredPasswords() => _isRecoveredPasswordsExpanded = !_isRecoveredPasswordsExpanded;
    private void ToggleHashes() => _isHashesExpanded = !_isHashesExpanded;
    private void ToggleRules() => _isRulesExpanded = !_isRulesExpanded;
    private string GetStatusBadgeClass(string? status) => status switch
    {
        "Completed" => "bg-success",
        "Running" or "In Progress" => "bg-primary",
        "Cancelled" => "bg-danger",
        "Initializing" => "bg-secondary",
        _ => "bg-dark"
    };

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }

    private static IEnumerable<string> GetRulesFromSpecs(JobSpecsEnvelope? specs)
    {
        if (specs is null)
        {
            return [];
        }

        var ruleContent = specs.PayloadCase switch
        {
            JobSpecsEnvelope.PayloadOneofCase.DictionaryJobSpecs => specs.DictionaryJobSpecs.RuleFileContent,
            JobSpecsEnvelope.PayloadOneofCase.CombinatorJobSpecs => specs.CombinatorJobSpecs.RuleFileContent,
            _ => string.Empty
        };

        return string.IsNullOrWhiteSpace(ruleContent)
            ? []
            : ruleContent.Split(['\r', '\n'], StringSplitOptions.RemoveEmptyEntries)
                .Select(rule => rule.Trim())
                .Where(rule => !string.IsNullOrWhiteSpace(rule));
    }

    private static AttackReportSummary BuildAttackReport(WorkUnitLifecycleExport? export)
    {
        if (export is null || export.Records.Count == 0)
        {
            return new AttackReportSummary();
        }

        var records = export.Records.ToList();
        var completed = records.Count(r => r.Outcome.StartsWith("completed", StringComparison.OrdinalIgnoreCase));
        var timedOut = records.Count(r => string.Equals(r.Outcome, "timed_out_requeued", StringComparison.OrdinalIgnoreCase));
        var retried = timedOut;

        var durations = records
            .Select(r => r.ProcessingDurationSeconds)
            .Where(v => v >= 0)
            .OrderBy(v => v)
            .ToList();

        var byAgent = records
            .GroupBy(r => string.IsNullOrWhiteSpace(r.AgentKey) ? "unknown" : r.AgentKey)
            .Select(group =>
            {
                var groupDurations = group
                    .Select(r => r.ProcessingDurationSeconds)
                    .Where(v => v >= 0)
                    .ToList();
                return new AgentReportSummary
                {
                    AgentKey = group.Key,
                    TotalWorkUnits = group.Count(),
                    CompletedWorkUnits = group.Count(r => r.Outcome.StartsWith("completed", StringComparison.OrdinalIgnoreCase)),
                    TimedOutWorkUnits = group.Count(r => string.Equals(r.Outcome, "timed_out_requeued", StringComparison.OrdinalIgnoreCase)),
                    MeanDurationSeconds = groupDurations.Count > 0 ? groupDurations.Average() : 0
                };
            })
            .ToList();

        var chunks = records
            .GroupBy(r => BuildChunkGroupKey(r.Mode, r.ChunkSummary))
            .Select(group =>
            {
                var ordered = group
                    .OrderBy(r => r.AssignedAt?.ToDateTime() ?? DateTime.MinValue)
                    .ToList();
                var durationsForChunk = ordered
                    .Select(r => r.ProcessingDurationSeconds)
                    .Where(v => v >= 0)
                    .ToList();
                var first = ordered[0];
                var parsed = ParseChunkSummary(first.Mode, first.ChunkSummary);
                return new ChunkReportSummary
                {
                    Mode = parsed.ModeLabel,
                    Display = parsed,
                    AttemptCount = ordered.Count,
                    Agents = ordered
                        .Select(r => string.IsNullOrWhiteSpace(r.AgentKey) ? "unknown" : r.AgentKey)
                        .Distinct(StringComparer.Ordinal)
                        .ToList(),
                    FinalOutcome = ordered[^1].Outcome,
                    MeanDurationSeconds = durationsForChunk.Count > 0 ? durationsForChunk.Average() : 0,
                    RecoveredCount = ordered.Sum(r => r.RecoveredCount),
                    Attempts = ordered.Select(r => new ChunkAttemptSummary
                    {
                        RequestId = r.RequestId,
                        AgentKey = string.IsNullOrWhiteSpace(r.AgentKey) ? "unknown" : r.AgentKey,
                        Outcome = r.Outcome,
                        ProcessingDurationSeconds = r.ProcessingDurationSeconds,
                        RecoveredCount = r.RecoveredCount,
                        AssignedAtUtc = r.AssignedAt?.ToDateTime().ToUniversalTime() ?? DateTime.MinValue
                    }).ToList()
                };
            })
            .OrderByDescending(chunk => chunk.Attempts.Max(a => a.AssignedAtUtc))
            .ToList();

        var total = records.Count;
        return new AttackReportSummary
        {
            TotalWorkUnits = total,
            CompletedWorkUnits = completed,
            TimedOutWorkUnits = timedOut,
            RetriedWorkUnits = retried,
            CompletedRatePercent = total > 0 ? completed * 100.0 / total : 0,
            TimeoutRatePercent = total > 0 ? timedOut * 100.0 / total : 0,
            MeanDurationSeconds = durations.Count > 0 ? durations.Average() : 0,
            P95DurationSeconds = Percentile(durations, 0.95),
            ByAgent = byAgent,
            Chunks = chunks
        };
    }

    private static string BuildChunkGroupKey(string? mode, string? chunkSummary)
    {
        var parsed = ParseChunkSummary(mode, chunkSummary);
        return string.Join("|", [
            parsed.ModeLabel,
            parsed.Title,
            parsed.PrimaryRange,
            parsed.SecondaryTitle,
            parsed.SecondaryRange
        ]);
    }

    private static ChunkDisplaySummary ParseChunkSummary(string? mode, string? chunkSummary)
    {
        var normalizedMode = string.IsNullOrWhiteSpace(mode) ? "unknown" : mode;
        var summary = chunkSummary?.Trim() ?? string.Empty;

        if (summary.StartsWith("mask=", StringComparison.OrdinalIgnoreCase))
        {
            var mask = ExtractBetween(summary, "mask=", ";range=");
            var range = ExtractAfter(summary, ";range=");
            return new ChunkDisplaySummary
            {
                ModeLabel = normalizedMode,
                Title = $"Mask: {mask}",
                PrimaryRange = string.IsNullOrWhiteSpace(range) ? string.Empty : $"Range: {range}"
            };
        }

        if (summary.StartsWith("wordlist=", StringComparison.OrdinalIgnoreCase))
        {
            var wordlist = ExtractBetween(summary, "wordlist=", ";bytes=");
            var range = ExtractAfter(summary, ";bytes=");
            return new ChunkDisplaySummary
            {
                ModeLabel = normalizedMode,
                Title = $"Wordlist: {wordlist}",
                PrimaryRange = string.IsNullOrWhiteSpace(range) ? string.Empty : $"Bytes: {range}"
            };
        }

        if (summary.StartsWith("dictionary_url=", StringComparison.OrdinalIgnoreCase))
        {
            var urlValue = ExtractAfter(summary, "dictionary_url=");
            if (Uri.TryCreate(urlValue, UriKind.Absolute, out var uri))
            {
                var name = Uri.UnescapeDataString(uri.Segments.LastOrDefault()?.Trim('/') ?? "unknown");
                var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
                var startByte = query.TryGetValue("startByte", out var startValue) ? startValue.ToString() : "0";
                var endByte = query.TryGetValue("endByte", out var endValue) ? endValue.ToString() : "EOF";
                return new ChunkDisplaySummary
                {
                    ModeLabel = normalizedMode,
                    Title = $"Wordlist: {name}",
                    PrimaryRange = $"Bytes: {startByte} - {endByte}"
                };
            }
        }

        if (summary.StartsWith("left=", StringComparison.OrdinalIgnoreCase) && summary.Contains(";right=", StringComparison.OrdinalIgnoreCase))
        {
            var splitIndex = summary.IndexOf(";right=", StringComparison.OrdinalIgnoreCase);
            var leftSegment = splitIndex >= 0 ? summary[..splitIndex] : summary;
            var rightSegment = splitIndex >= 0 ? summary[(splitIndex + 1)..] : string.Empty;
            var (leftName, leftRange) = ParseBracketedSegment(leftSegment, "left=");
            var (rightName, rightRange) = ParseBracketedSegment(rightSegment, "right=");
            return new ChunkDisplaySummary
            {
                ModeLabel = normalizedMode,
                Title = $"Left: {leftName}",
                PrimaryRange = string.IsNullOrWhiteSpace(leftRange) ? string.Empty : $"Bytes: {leftRange}",
                SecondaryTitle = $"Right: {rightName}",
                SecondaryRange = string.IsNullOrWhiteSpace(rightRange) ? string.Empty : $"Bytes: {rightRange}"
            };
        }

        return new ChunkDisplaySummary
        {
            ModeLabel = normalizedMode,
            Title = summary,
            PrimaryRange = string.Empty
        };
    }

    private static string ExtractBetween(string text, string startMarker, string endMarker)
    {
        var start = text.IndexOf(startMarker, StringComparison.OrdinalIgnoreCase);
        if (start < 0)
        {
            return string.Empty;
        }

        start += startMarker.Length;
        var end = text.IndexOf(endMarker, start, StringComparison.OrdinalIgnoreCase);
        return end >= start ? text[start..end] : text[start..];
    }

    private static string ExtractAfter(string text, string marker)
    {
        var start = text.IndexOf(marker, StringComparison.OrdinalIgnoreCase);
        if (start < 0)
        {
            return string.Empty;
        }

        return text[(start + marker.Length)..];
    }

    private static (string Name, string Range) ParseBracketedSegment(string segment, string prefix)
    {
        var value = ExtractAfter(segment, prefix);
        var bracketStart = value.LastIndexOf('[');
        var bracketEnd = value.LastIndexOf(']');
        if (bracketStart < 0 || bracketEnd <= bracketStart)
        {
            return (value, string.Empty);
        }

        return (value[..bracketStart], value[(bracketStart + 1)..bracketEnd]);
    }

    private static double Percentile(IReadOnlyList<double> sortedValues, double percentile)
    {
        if (sortedValues.Count == 0)
        {
            return 0;
        }

        if (percentile <= 0)
        {
            return sortedValues[0];
        }

        if (percentile >= 1)
        {
            return sortedValues[sortedValues.Count - 1];
        }

        var index = (int)Math.Ceiling(percentile * sortedValues.Count) - 1;
        index = Math.Clamp(index, 0, sortedValues.Count - 1);
        return sortedValues[index];
    }
}