@page "/wordlists"
@inject WordlistService WordlistService
@rendermode InteractiveServer

<PageTitle>Wordlists</PageTitle>

<h1>Wordlists</h1>

<div class="row">
    <div class="col-md-6 mb-4">
        <div class="card">
            <div class="card-header">Upload New Wordlist</div>
            <div class="card-body">
                <div class="mb-3">
                    <InputCheckbox @bind-Value="_allowOverwrite" class="form-check-input" id="overwriteCheckbox" />
                    <label class="form-check-label" for="overwriteCheckbox">Allow overwriting existing wordlists</label>
                </div>
                <div class="mb-3">
                    <label class="form-label">Select Wordlist File (.txt)</label>
                    <InputFile OnChange="LoadFiles" class="form-control" accept=".txt" />
                </div>

                @if (_isUploading)
                {
                    <div class="d-flex align-items-center text-primary mt-3">
                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                        <span>Uploading and building binary index... Please do not close this page.</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(_uploadMessage))
                {
                    <div class="alert alert-info mt-3 mb-0">@_uploadMessage</div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-header">Available Wordlists</div>
            <ul class="list-group list-group-flush">
                @foreach (var wordlist in _availableWordlists)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        @wordlist
                        <div>
                            <span class="badge bg-success rounded-pill me-2">Indexed</span>
                            <button class="btn btn-sm btn-outline-danger border-0 pt-0" @onclick="() => DeleteWordlist(wordlist)" title="Delete wordlist">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash" viewBox="0 0 16 16">
                                    <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z"/>
                                    <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z"/>
                                </svg>
                            </button>
                        </div>
                    </li>
                }
                @if (_availableWordlists.Count == 0)
                {
                    <li class="list-group-item text-muted">No wordlists available.</li>
                }
            </ul>
        </div>
    </div>
</div>

@code {
    private bool _isUploading;
    private string? _uploadMessage;
    private List<string> _availableWordlists = [];
    private bool _allowOverwrite = false; // Flag to allow overwriting existing wordlists

    // Allow up to 100 GB file uploads (adjust as needed)
    private const long MaxAllowedSize = 100L * 1024 * 1024 * 1024;

    protected override void OnInitialized() => RefreshWordlists();

    private void RefreshWordlists() => _availableWordlists = WordlistService.GetAvailableWordlists().ToList();

    private async Task LoadFiles(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;

        _isUploading = true;
        _uploadMessage = null;
        StateHasChanged();

        try
        {
            // OpenReadStream streams the file to the server in small chunks safely over SignalR
            using var stream = file.OpenReadStream(MaxAllowedSize);
            await WordlistService.UploadWordlistAsync(file.Name, stream, _allowOverwrite);

            _uploadMessage = $"Successfully uploaded and indexed '{file.Name}'.";
            RefreshWordlists();
        }
        catch (Exception ex)
        {
            _uploadMessage = $"Error uploading file: {ex.Message}";
        }
        finally
        {
            _isUploading = false;
            StateHasChanged();
        }
    }

    private void DeleteWordlist(string fileName)
    {
        try
        {
            WordlistService.DeleteWordlist(fileName);
            _uploadMessage = $"Successfully deleted '{fileName}'.";
            RefreshWordlists();
        }
        catch (Exception ex)
        {
            _uploadMessage = $"Error deleting wordlist: {ex.Message}";
            StateHasChanged();
        }
    }
}