@page "/recovered-passwords"
@rendermode InteractiveServer
@using DPCS.DAL
@using DPCS.DAL.Entities
@using DPCS.Shared
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<DpcsDbContext> DbFactory

<PageTitle>Recovered Passwords</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Recovered Passwords</h1>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-secondary" @onclick="LoadDataAsync">
            <span class="bi bi-arrow-clockwise" aria-hidden="true"></span> Refresh
        </button>
    </div>
</div>

@if (_isLoading)
{
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
}
else if (!_passwords.Any())
{
    <div class="alert alert-secondary text-center" role="alert">
        No recovered passwords found in the database.
    </div>
}
else
{
    <div class="table-responsive bg-white rounded shadow-sm border">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Plaintext</th>
                    <th>Hash</th>
                    <th>Hash Type</th>
                    <th>Mode</th>
                    <th>Cracked At</th>
                    <th>Time Taken</th>
                    <th>Job ID</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var pwd in _passwords)
                {
                    <tr>
                        <td><strong class="text-success">@pwd.Plaintext</strong></td>
                        <td class="text-truncate" style="max-width: 250px;" title="@pwd.Hash">
                            <code class="text-secondary user-select-all">@pwd.Hash</code>
                        </td>
                        <td><span class="small">@HashTypeMap.GetHashTypeName(pwd.HashType)</span></td>
                        <td>@((AttackMode)pwd.AttackMode)</td>
                        <td>@pwd.CrackedAt.ToLocalTime().ToString("MMM dd, yyyy HH:mm:ss")</td>
                        <td>@pwd.TimeTaken.ToString(@"hh\:mm\:ss")</td>
                        <td>
                            <a href="/job-details/@Uri.EscapeDataString(pwd.JobId)" class="text-decoration-none small text-truncate d-inline-block" style="max-width: 120px;" title="@pwd.JobId">
                                @pwd.JobId.Split('/').LastOrDefault()
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private bool _isLoading = true;
    private List<CrackedPasswordEntity> _passwords = [];

    protected override async Task OnInitializedAsync() => await LoadDataAsync();

    private async Task LoadDataAsync()
    {
        _isLoading = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            
            // Query directly from the DB! We use AsNoTracking() because it's a read-only view, 
            // which drastically improves EF Core memory allocation performance.
            _passwords = await db.CrackedPasswords
                .AsNoTracking()
                .OrderByDescending(p => p.CrackedAt)
                .ToListAsync();
        }
        finally
        {
            _isLoading = false;
        }
    }
}