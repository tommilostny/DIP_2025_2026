@inherits LayoutComponentBase

<Microsoft.AspNetCore.Components.Sections.SectionOutlet SectionName="modal-layer" @rendermode="InteractiveServer" />

<div class="page modern-layout">
    
    <div class="sidebar modern-sidebar">
        <NavMenu />
    </div>

    <main class="modern-main">
        <div class="top-row px-4 modern-topbar d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-2 text-muted d-none d-sm-flex">
                <span class="bi bi-hdd-network text-primary fs-5"></span>
                <span class="small fw-semibold text-uppercase" style="letter-spacing: 1px;">Coordinator Node</span>
            </div>
            
            <ClusterStatusBadge />
        </div>

        <article class="content px-4 py-4 animate-fade-in-up">
            @Body
        </article>
    </main>
</div>

<style>
    /* Global Typography & Background */
    body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif !important;
        background-color: #f8fafc !important;
        color: #334155;
    }

    h1, h2, h3, h4, h5, h6 {
        font-weight: 600;
        color: #0f172a;
        letter-spacing: -0.02em;
    }

    /* Layout Structure */
    .modern-layout {
        display: flex;
        min-height: 100vh;
    }

    .modern-sidebar {
        background: linear-gradient(180deg, #0f172a 0%, #1e293b 100%);
        width: 280px;
        flex-shrink: 0;
        box-shadow: 4px 0 15px rgba(0,0,0,0.05);
        z-index: 10;
    }

    .modern-main {
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        overflow-x: hidden;
        background-color: #f8fafc;
    }

    /* Topbar styling */
    .modern-topbar {
        background-color: rgba(255, 255, 255, 0.8) !important;
        backdrop-filter: blur(10px);
        border-bottom: 1px solid #e2e8f0;
        height: 70px;
        box-shadow: 0 1px 2px rgba(0,0,0,0.02);
        position: sticky;
        top: 0;
        z-index: 5;
    }

    /* Content Area */
    .content {
        max-width: 1400px;
        margin: 0 auto;
        width: 100%;
    }

    /* Animations */
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(15px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @@keyframes pulseIndicator {
        0% { opacity: 0.6; }
        50% { opacity: 1; }
        100% { opacity: 0.6; }
    }

    .animate-fade-in-up {
        animation: fadeInUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .animate-pulse {
        animation: pulseIndicator 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }

    /* Global Component Restyling */
    .card {
        background: #ffffff;
        border: 1px solid rgba(226, 232, 240, 0.8) !important;
        border-radius: 16px !important;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -2px rgba(0, 0, 0, 0.025) !important;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        overflow: hidden;
    }
    
    .card:hover {
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.08), 0 4px 6px -4px rgba(0, 0, 0, 0.04) !important;
        transform: translateY(-2px);
    }

    .card-header {
        background-color: #ffffff !important;
        border-bottom: 1px solid #f1f5f9 !important;
        padding: 1rem 1.25rem !important;
        font-weight: 600;
        color: #0f172a;
    }

    /* Buttons */
    .btn {
        border-radius: 8px;
        font-weight: 500;
        transition: all 0.2s ease;
    }
    
    .btn:hover {
        transform: translateY(-1px);
    }
</style>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
