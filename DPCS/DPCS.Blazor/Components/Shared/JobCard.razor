@implements IDisposable

<div class="card">
    <div class="card-header">
        Job ID:<br />@Job.JobId
    </div>
    <div class="card-body">
        <h5 class="card-title">Job Details</h5>
        <p>
            <strong>Attack mode:</strong> @Job.ModeId (@(Job.ModeId == (int)AttackMode.Mask ? "Mask" : "Dictionary"))
            <br />
            @if (Job.ModeId == (int)AttackMode.Mask && _maskJobSpecs is not null)
            {
                <strong>Mask: </strong> @_maskJobSpecs.Mask
                <br />
                @if (!string.IsNullOrWhiteSpace(_maskJobSpecs.CustomCharset1))
                {
                    <strong>Charset 1 (?1): </strong> @_maskJobSpecs.CustomCharset1<br />
                }
                @if (!string.IsNullOrWhiteSpace(_maskJobSpecs.CustomCharset2))
                {
                    <strong>Charset 2 (?2): </strong> @_maskJobSpecs.CustomCharset2<br />
                }
                @if (!string.IsNullOrWhiteSpace(_maskJobSpecs.CustomCharset3))
                {
                    <strong>Charset 3 (?3): </strong> @_maskJobSpecs.CustomCharset3<br />
                }
                @if (!string.IsNullOrWhiteSpace(_maskJobSpecs.CustomCharset4))
                {
                    <strong>Charset 4 (?4): </strong> @_maskJobSpecs.CustomCharset4<br />
                }
            }
            else if (Job.ModeId == (int)AttackMode.Dictionary && _dictionaryJobSpecs is not null)
            {
                <strong>Wordlists:</strong>
                <ul class="mb-0">
                    @foreach (var wordlist in _dictionaryJobSpecs.Wordlists)
                    {
                        <li>@wordlist</li>
                    }
                </ul>
            }
            <strong>Hash type:</strong> @Job.HashType (@HashTypeMap.GetHashTypeName(Job.HashType))
            <br />
            <strong style="cursor: pointer;" @onclick="ToggleHashes">
                Hashes (@(Job.Hashes?.Count ?? 0))
                <span class="float-end">@(_isHashesExpanded ? "▼" : "▶")</span>
            </strong>
            @if (_isHashesExpanded && Job is { Hashes: { Count: > 0 } })
            {
                <ul class="mb-0">
                    @foreach (var hash in Job.Hashes)
                    {
                        <li>@hash</li>
                    }
                </ul>
            }
            else
            {
                <br />
            }
            <strong>Chunk Attack seconds:</strong> @(_jobStatus?.ChunkAttackSeconds ?? 0)
            <br />
            <strong>Status:</strong> @(_jobStatus?.Status ?? "Loading...")
            <br />
            <strong>Progress:</strong> @(_jobStatus?.ProgressPercentage.ToString("F2") ?? "0.00")%
        </p>
        @if (_jobStatus is { ProgressPercentage: < 100 })
        {
            <button class="btn btn-danger btn-sm mt-2" @onclick="CancelJob">Cancel Job</button>
        }
    </div>
    <div class="card-footer">
        <h5 class="card-title mb-0" style="cursor: pointer;" @onclick="ToggleAgents">
            Active agents (@(_jobStatus?.Agents.Count ?? 0))
            @if (_jobStatus is { Agents: { Count: > 0 } })
            {
                <span class="float-end">@(_isAgentsExpanded ? "▼" : "▶")</span>
            }
        </h5>
        @if (_isAgentsExpanded && _jobStatus is { Agents: { Count: > 0 } })
        {
            <ul class="mt-2 mb-0">
                @foreach (var agentTelemetry in _jobStatus.Agents)
                {
                    <li>
                        @agentTelemetry.AgentId
                        @if (!float.IsNaN(agentTelemetry.RejectRate))
                        {
                            <ul>
                                <li>Current hashrate: @agentTelemetry.CurrentHashrate H/s</li>
                                <li>Temperature: @agentTelemetry.Temperature °C</li>
                                <li>Fan speed: @agentTelemetry.FanSpeed %</li>
                                <li>GPU utilization: @agentTelemetry.GpuUtilization %</li>
                                <li>Reject rate: @(agentTelemetry.RejectRate * 100) %</li>
                            </ul>
                        }
                    </li>
                }
            </ul>
        }
        <hr />
        <h5 class="card-title mb-0" style="cursor: pointer;" @onclick="ToggleRecoveredPasswords">
            Recovered passwords (@(_jobStatus?.RecoveredPasswords.Count ?? 0))
            @if (_jobStatus is { RecoveredPasswords: { Count: > 0 } })
            {
                <span class="float-end">@(_isRecoveredPasswordsExpanded ? "▼" : "▶")</span>
            }
        </h5>
        @if (_isRecoveredPasswordsExpanded && _jobStatus is { RecoveredPasswords: { Count: > 0 } })
        {
            <ul class="mt-2 mb-0">
                @foreach (var rec in _jobStatus.RecoveredPasswords)
                {
                    <li>@rec.Hash: <strong>@rec.Plaintext</strong></li>
                }
            </ul>
        }
    </div>
</div>

@code {
    [Parameter]
    public JobAssignment Job { get; set; } = default!;

    [Parameter]
    public ActorSystem ActorSystem { get; set; } = default!;

    private JobStatus? _jobStatus;
    private HashcatMaskJobSpecs? _maskJobSpecs;
    private HashcatDictionaryJobSpecs? _dictionaryJobSpecs;
    private readonly CancellationTokenSource _cts = new();
    private bool _isAgentsExpanded;
    private bool _isRecoveredPasswordsExpanded;
    private bool _isHashesExpanded;

    protected override async Task OnInitializedAsync()
    {
        await LoadJobStatus();
        await LoadJobSpecs();

        _ = Task.Run(async () =>
        {
            try
            {
                using var timer = new PeriodicTimer(TimeSpan.FromSeconds(5));
                while (await timer.WaitForNextTickAsync(_cts.Token))
                {
                    await InvokeAsync(LoadJobStatus);
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch (OperationCanceledException) { }
        });
    }

    private async Task LoadJobStatus()
    {
        var jobCoordinator = ActorSystem.Cluster().GetJobCoordinatorGrain(Job.JobId);
        _jobStatus = await jobCoordinator.GetJobStatus(CancellationToken.None);
    }

    private async Task LoadJobSpecs()
    {
        var jobCoordinator = ActorSystem.Cluster().GetJobCoordinatorGrain(Job.JobId);
        switch (Job)
        {
            case { ModeId: (int)AttackMode.Mask }:
                _maskJobSpecs = await jobCoordinator.GetMaskJobSpecs(CancellationToken.None);
                break;
            case { ModeId: (int)AttackMode.Dictionary }:
                _dictionaryJobSpecs = await jobCoordinator.GetDictionaryJobSpecs(CancellationToken.None);
                break;
            default:
                break;
        }
    }

    private async Task CancelJob()
    {
        var jobManager = ActorSystem.Cluster().GetJobManagerGrain("root");
        await jobManager.CancelJob(new JobId { Id = Job.JobId }, CancellationToken.None);
    
        await _cts.CancelAsync();
        await LoadJobStatus();
    }

    private void ToggleAgents()
    {
        _isAgentsExpanded = !_isAgentsExpanded;
    }

    private void ToggleRecoveredPasswords()
    {
        _isRecoveredPasswordsExpanded = !_isRecoveredPasswordsExpanded;
    }

    private void ToggleHashes()
    {
        _isHashesExpanded = !_isHashesExpanded;
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }
}