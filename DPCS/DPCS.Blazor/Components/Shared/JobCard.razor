@implements IDisposable
@using DPCS.DAL.Entities
@using DPCS.Shared

<div class="card h-100 shadow-sm border-0">
    <div class="card-header bg-light d-flex justify-content-between align-items-center">
        <span class="text-truncate me-2 font-monospace small" title="@ResolvedJobId">
            <strong>@ResolvedJobId.Split('/').LastOrDefault()</strong>
        </span>
        @GetStatusBadge(ResolvedStatus)
    </div>
    <div class="card-body">
        <h5 class="card-title">
            @(((AttackMode)ResolvedModeId).ToString()) Attack
        </h5>
        <h6 class="card-subtitle mb-3 text-muted">
            @HashTypeMap.GetHashTypeName(ResolvedHashType)
        </h6>

        @if (ResolvedStatus is "Running" or "In Progress" && ActorSystem is not null)
        {
            <div class="d-flex align-items-center gap-2 mb-2">
                <span class="small text-secondary">Progress:</span>
                <span class="badge bg-info">@(Math.Round(ResolvedProgress, 2).ToString("F2")) %</span>
            </div>
            <div class="progress mb-3" style="height: 8px;">
                <div class="progress-bar progress-bar-striped progress-bar-animated" 
                     role="progressbar" 
                     style="width: @Math.Round(ResolvedProgress)%;" 
                     aria-valuenow="@Math.Round(ResolvedProgress)" 
                     aria-valuemin="0" 
                     aria-valuemax="100"></div>
            </div>
            <div class="d-flex align-items-center gap-2 mb-3">
                <span class="small text-secondary">Active Agents:</span>
                <span class="badge bg-info">@(_activeJobStatus?.Agents.Count ?? 0)</span>
            </div>
        }

        <div class="d-flex flex-column gap-1 small text-secondary">
            @if (ResolvedStartTime.HasValue)
            {
                <div><strong>Start:</strong> @ResolvedStartTime.Value.ToLocalTime().ToString("HH:mm:ss")</div>
            }
            @if (ResolvedEndTime.HasValue)
            {
                <div><strong>End:</strong> @ResolvedEndTime.Value.ToLocalTime().ToString("HH:mm:ss")</div>
            }
            @if (ResolvedStartTime.HasValue)
            {
                <div><strong>Duration:</strong> @GetDuration()</div>
            }
        </div>
    </div>
    <div class="card-footer bg-white border-top-0 pt-0">
        <a href="/job-details/@Uri.EscapeDataString(ResolvedJobId)" class="btn btn-sm btn-outline-primary w-100">View Details</a>
    </div>
</div>

@code {
    [Parameter] public JobRecordEntity? DbJob { get; set; }
    [Parameter] public JobAssignment? ActiveJob { get; set; }
    [Parameter] public ActorSystem? ActorSystem { get; set; }

    private JobStatus? _activeJobStatus;
    private readonly CancellationTokenSource _cts = new();

    private string ResolvedJobId => DbJob?.JobId ?? ActiveJob?.JobId ?? "";
    private int ResolvedModeId => DbJob?.AttackMode ?? ActiveJob?.ModeId ?? 0;
    private int ResolvedHashType => DbJob?.HashType ?? ActiveJob?.HashType ?? 0;
    private string ResolvedStatus => DbJob?.Status ?? _activeJobStatus?.Status ?? "Initializing";
    private double ResolvedProgress => DbJob?.ProgressPercentage ?? _activeJobStatus?.ProgressPercentage ?? double.NaN;
    private DateTime? ResolvedStartTime => DbJob?.StartTime;
    private DateTime? ResolvedEndTime => DbJob?.EndTime;

    protected override async Task OnInitializedAsync()
    {
        await LoadJobStatus();

        _ = Task.Run(async () =>
        {
            try
            {
                using var timer = new PeriodicTimer(TimeSpan.FromSeconds(5));
                while (await timer.WaitForNextTickAsync(_cts.Token))
                {
                    await InvokeAsync(LoadJobStatus);
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch (OperationCanceledException) { }
        });
    }

    private async Task LoadJobStatus()
    {
        if (ActiveJob is not null && ActorSystem is not null)
        {
            var jobCoordinator = ActorSystem.Cluster().GetJobCoordinatorGrain(ActiveJob.JobId);
            _activeJobStatus = await jobCoordinator.GetJobStatus(CancellationToken.None);
        }
    }

    private string GetDuration()
    {
        if (!ResolvedStartTime.HasValue) return "N/A";
        var end = ResolvedEndTime ?? DateTime.UtcNow;
        var span = end - ResolvedStartTime.Value;
        return $"{(int)span.TotalHours:D2}:{span.Minutes:D2}:{span.Seconds:D2}";
    }

    private RenderFragment GetStatusBadge(string status) => builder =>
    {
        var badgeClass = status switch
        {
            "Completed" => "bg-success",
            "Running" or "In Progress" => "bg-primary",
            "Cancelled" => "bg-danger",
            "Initializing" => "bg-secondary",
            _ => "bg-dark"
        };

        builder.OpenElement(0, "span");
        builder.AddAttribute(1, "class", $"badge {badgeClass}");
        builder.AddContent(2, status);
        builder.CloseElement();
    };

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }
}