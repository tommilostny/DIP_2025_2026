@inject WordlistService WordlistService

<div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-light d-flex justify-content-between align-items-center">
        <strong>Attack Report</strong>
        <div class="d-flex gap-2 flex-wrap">
            <a class="btn btn-outline-primary btn-sm" href="/api/jobs/@JobId/work-units">Export JSON</a>
            <a class="btn btn-outline-secondary btn-sm" href="/api/jobs/@JobId/work-units?format=csv">Export CSV</a>
        </div>
    </div>
    <div class="card-body">
        <div class="row g-2 mb-3">
            <div class="col-sm-6 col-lg-3">
                <div class="border rounded p-2 bg-light">
                    <div class="small text-muted">Total WU</div>
                    <div class="fw-semibold">@AttackReport.TotalWorkUnits</div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="border rounded p-2 bg-light">
                    <div class="small text-muted">Completed WU</div>
                    <div class="fw-semibold">@AttackReport.CompletedWorkUnits (@AttackReport.CompletedRatePercent.ToString("F1")%)</div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="border rounded p-2 bg-light">
                    <div class="small text-muted">Timed Out WU</div>
                    <div class="fw-semibold">@AttackReport.TimedOutWorkUnits (@AttackReport.TimeoutRatePercent.ToString("F1")%)</div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="border rounded p-2 bg-light">
                    <div class="small text-muted">Retry WU</div>
                    <div class="fw-semibold">@AttackReport.RetriedWorkUnits</div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="border rounded p-2 bg-light">
                    <div class="small text-muted">Mean WU Duration</div>
                    <div class="fw-semibold">@FormatDurationSeconds(AttackReport.MeanDurationSeconds)</div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="border rounded p-2 bg-light">
                    <div class="small text-muted">P95 WU Duration</div>
                    <div class="fw-semibold">@FormatDurationSeconds(AttackReport.P95DurationSeconds)</div>
                </div>
            </div>
        </div>

        @if (AttackReport.ByAgent.Count > 0)
        {
            <div class="small text-muted mb-2">
                Participating agents: @GetParticipatingAgentCount()
            </div>
            <div class="table-responsive mb-3">
                <table class="table table-sm table-bordered mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Agent</th>
                            <th>Total WU</th>
                            <th>Completed</th>
                            <th>Timed Out</th>
                            <th>Mean Duration</th>
                            <th>Avg Hashrate</th>
                            <th>Avg Temp</th>
                            <th>Avg Fan</th>
                            <th>Avg GPU Util</th>
                            <th>Avg VRAM Util</th>
                            <th>Avg VRAM Used / Total</th>
                            <th>Reject</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in AttackReport.ByAgent.OrderByDescending(x => x.TotalWorkUnits))
                        {
                            var agentStatusReport = GetAgentStatusForReport(item.AgentKey);
                            <tr>
                                <td class="font-monospace small" rowspan="@GetReportAgentRowspan(agentStatusReport)">@item.AgentKey</td>
                                <td>@item.TotalWorkUnits</td>
                                <td>@item.CompletedWorkUnits</td>
                                <td>@item.TimedOutWorkUnits</td>
                                <td>@FormatDurationSeconds(item.MeanDurationSeconds)</td>
                                <td>@FormatGpuHashrate(agentStatusReport?.Telemetry.CurrentHashrate ?? -1)</td>
                                <td>@FormatIntMetric(agentStatusReport?.Telemetry.Temperature ?? -1, "°C")</td>
                                <td>@FormatIntMetric(agentStatusReport?.Telemetry.FanSpeed ?? -1, "%")</td>
                                <td>@FormatIntMetric(agentStatusReport?.Telemetry.GpuUtilization ?? -1, "%")</td>
                                <td>@FormatAverageGpuUtilization(agentStatusReport?.Telemetry.GpuDevices)</td>
                                <td>@FormatAverageVramUsage(agentStatusReport?.Telemetry.GpuDevices)</td>
                                <td>@FormatRejectRate(agentStatusReport?.Telemetry.RejectRate)</td>
                            </tr>

                            @if (agentStatusReport is not null && agentStatusReport.Telemetry.GpuDevices.Count > 0)
                            {
                                @foreach (var gpu in agentStatusReport.Telemetry.GpuDevices.OrderBy(g => g.DeviceIndex))
                                {
                                    <tr class="assignment-row">
                                        <td colspan="4">
                                            <span class="badge rounded-pill bg-dark text-white me-2">GPU @gpu.DeviceIndex</span>
                                            @if (!string.IsNullOrWhiteSpace(gpu.DeviceName))
                                            {
                                                <span class="badge rounded-pill bg-secondary">@gpu.DeviceName</span>
                                            }
                                        </td>
                                        <td>@FormatGpuHashrate(gpu.CurrentHashrate)</td>
                                        <td>@FormatIntMetric(gpu.Temperature, "°C")</td>
                                        <td>@FormatIntMetric(gpu.FanSpeed, "%")</td>
                                        <td>@FormatIntMetric(gpu.GpuUtilization, "%")</td>
                                        <td>@FormatIntMetric(gpu.VramUtilization, "%")</td>
                                        <td>@FormatVramMetric(gpu.VramUsedBytes, gpu.VramTotalBytes, gpu.VramUtilization)</td>
                                        <td class="text-muted">-</td>
                                    </tr>
                                }
                            }
                        }
                    </tbody>
                </table>
            </div>
        }

        @if (AttackReport.Chunks.Count > 0)
        {
            <div class="d-flex justify-content-between align-items-center mb-2 mt-3">
                <div>
                    <strong>Chunk Details</strong>
                    <span class="text-muted small ms-2">@AttackReport.Chunks.Count unique chunks, @AttackReport.Chunks.Sum(c => c.AttemptCount) attempts</span>
                </div>
                <div class="d-flex gap-2 align-items-center">
                    @if (_isChunkDetailsExpanded)
                    {
                        <span class="small text-muted">Showing @GetChunkRangeLabel()</span>
                    }
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ToggleChunkDetails">
                        @(_isChunkDetailsExpanded ? "Hide" : "Show")
                    </button>
                </div>
            </div>

            @if (_isChunkDetailsExpanded)
            {
                <div class="table-responsive mb-3">
                    <table class="table table-sm table-bordered align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Chunk</th>
                                <th>Mode</th>
                                <th>Attempts</th>
                                <th>Agents</th>
                                <th>Final Outcome</th>
                                <th>Mean Duration</th>
                                <th>Recovered</th>
                                <th>Attempt History</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var chunk in GetVisibleChunks())
                            {
                                <tr>
                                    <td>
                                        <div class="small fw-semibold">@chunk.Display.Title</div>
                                        @if (!string.IsNullOrWhiteSpace(chunk.Display.PrimaryRange))
                                        {
                                            <div class="small text-muted">@chunk.Display.PrimaryRange</div>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(chunk.Display.SecondaryTitle))
                                        {
                                            <div class="small fw-semibold mt-2">@chunk.Display.SecondaryTitle</div>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(chunk.Display.SecondaryRange))
                                        {
                                            <div class="small text-muted">@chunk.Display.SecondaryRange</div>
                                        }
                                    </td>
                                    <td>@chunk.Mode</td>
                                    <td>@chunk.AttemptCount</td>
                                    <td>
                                        @foreach (var agent in chunk.Agents)
                                        {
                                            <div class="font-monospace small">@agent</div>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge @GetOutcomeBadgeClass(chunk.FinalOutcome)">@FormatOutcome(chunk.FinalOutcome)</span>
                                    </td>
                                    <td>@FormatDurationSeconds(chunk.MeanDurationSeconds)</td>
                                    <td>@chunk.RecoveredCount</td>
                                    <td>
                                        @foreach (var attempt in chunk.Attempts)
                                        {
                                            <div class="border rounded p-1 mb-1 bg-light-subtle">
                                                <div class="font-monospace small">@attempt.RequestId</div>
                                                <div class="small">@attempt.AgentKey</div>
                                                <div class="small text-muted">Assigned: @attempt.AssignedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</div>
                                                <div class="small">
                                                    <span class="badge @GetOutcomeBadgeClass(attempt.Outcome)">@FormatOutcome(attempt.Outcome)</span>
                                                    <span class="ms-2">@FormatDurationSeconds(attempt.ProcessingDurationSeconds)</span>
                                                    @if (attempt.RecoveredCount > 0)
                                                    {
                                                        <span class="ms-2">Recovered: @attempt.RecoveredCount</span>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (GetChunkPageCount() > 1)
                {
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="small text-muted">Page @_chunkDetailsPage of @GetChunkPageCount()</div>
                        <div class="btn-group" role="group" aria-label="Chunk details pagination">
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ShowPreviousChunkPage" disabled="@(_chunkDetailsPage <= 1)">Previous 10</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ShowNextChunkPage" disabled="@(_chunkDetailsPage >= GetChunkPageCount())">Next 10</button>
                        </div>
                    </div>
                }
            }
        }

        <div class="row g-3 mt-2">
            <div class="col-12">
                <div class="border rounded p-2 bg-white">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <strong>Chart: Load Balancing (Agent Work Share)</strong>
                        <a class="btn btn-sm btn-outline-dark" download="@($"{JobId}_load_balancing.png")" href="/api/jobs/@JobId/report-chart?type=load-balancing&amp;ts=@ChartCacheBust">Download PNG</a>
                    </div>
                    <img src="/api/jobs/@JobId/report-chart?type=load-balancing&amp;ts=@ChartCacheBust" alt="Load balancing chart" class="img-fluid border rounded" />
                </div>
            </div>
            <div class="col-12">
                <div class="border rounded p-2 bg-white">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <strong>Chart: Mean Work Time Per Agent</strong>
                        <a class="btn btn-sm btn-outline-dark" download="@($"{JobId}_mean_work_time_per_agent.png")" href="/api/jobs/@JobId/report-chart?type=mean-work-time&amp;ts=@ChartCacheBust">Download PNG</a>
                    </div>
                    <img src="/api/jobs/@JobId/report-chart?type=mean-work-time&amp;ts=@ChartCacheBust" alt="Mean work time per agent chart" class="img-fluid border rounded" />
                </div>
            </div>
            <div class="col-12">
                <div class="border rounded p-2 bg-white">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <strong>Chart: GPU Usage Over Time (Per Agent + All Agents Avg)</strong>
                        <a class="btn btn-sm btn-outline-dark" download="@($"{JobId}_gpu_usage_over_time.png")" href="/api/jobs/@JobId/report-chart?type=gpu-usage-time&amp;ts=@ChartCacheBust">Download PNG</a>
                    </div>
                    <img src="/api/jobs/@JobId/report-chart?type=gpu-usage-time&amp;ts=@ChartCacheBust" alt="GPU usage over time chart" class="img-fluid border rounded" />
                </div>
            </div>
            <div class="col-12">
                <div class="border rounded p-2 bg-white">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <strong>Chart: WU Duration Distribution (P95)</strong>
                        <a class="btn btn-sm btn-outline-dark" download="@($"{JobId}_wu_duration_distribution.png")" href="/api/jobs/@JobId/report-chart?type=duration-distribution&amp;ts=@ChartCacheBust">Download PNG</a>
                    </div>
                    <img src="/api/jobs/@JobId/report-chart?type=duration-distribution&amp;ts=@ChartCacheBust" alt="Work-unit duration distribution chart" class="img-fluid border rounded" />
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string JobId { get; set; } = string.Empty;
    [Parameter] public AttackReportSummary AttackReport { get; set; } = new();
    [Parameter] public JobStatus? JobStatus { get; set; }
    [Parameter] public long ChartCacheBust { get; set; }

    private bool _isChunkDetailsExpanded = true;
    private int _chunkDetailsPage = 1;
    private const int ChunkDetailsPageSize = 10;

    protected override void OnParametersSet()
    {
        EnsureChunkPageInRange();
    }

    private IReadOnlyList<ChunkReportSummary> GetVisibleChunks()
    {
        if (AttackReport.Chunks.Count == 0)
        {
            return [];
        }

        var skip = (_chunkDetailsPage - 1) * ChunkDetailsPageSize;
        return AttackReport.Chunks.Skip(skip).Take(ChunkDetailsPageSize).ToList();
    }

    private int GetChunkPageCount()
    {
        var total = AttackReport.Chunks.Count;
        return total == 0 ? 1 : (int)Math.Ceiling(total / (double)ChunkDetailsPageSize);
    }

    private string GetChunkRangeLabel()
    {
        var total = AttackReport.Chunks.Count;
        if (total == 0)
        {
            return "Showing 0 of 0";
        }

        var start = ((_chunkDetailsPage - 1) * ChunkDetailsPageSize) + 1;
        var end = Math.Min(total, _chunkDetailsPage * ChunkDetailsPageSize);
        return $"Showing {start}-{end} of {total}";
    }

    private void ShowPreviousChunkPage()
    {
        if (_chunkDetailsPage > 1)
        {
            _chunkDetailsPage--;
        }
    }

    private void ShowNextChunkPage()
    {
        if (_chunkDetailsPage < GetChunkPageCount())
        {
            _chunkDetailsPage++;
        }
    }

    private void ToggleChunkDetails() => _isChunkDetailsExpanded = !_isChunkDetailsExpanded;

    private void EnsureChunkPageInRange()
    {
        var pageCount = GetChunkPageCount();
        _chunkDetailsPage = Math.Clamp(_chunkDetailsPage, 1, pageCount);
    }

    private int GetParticipatingAgentCount()
    {
        if (JobStatus is null)
        {
            return 0;
        }

        if (JobStatus.ParticipatingAgents.Count > 0)
        {
            return JobStatus.ParticipatingAgents.Count;
        }

        return AttackReport.ByAgent.Count;
    }

    private int GetReportAgentRowspan(AgentStatus? status)
        => 1 + (status?.Telemetry.GpuDevices.Count ?? 0);

    private AgentStatus? GetAgentStatusForReport(string agentKey)
    {
        if (JobStatus is null)
        {
            return null;
        }

        var participating = JobStatus.ParticipatingAgents.FirstOrDefault(agent =>
            string.Equals($"{agent.Telemetry.AgentId.Address}/{agent.Telemetry.AgentId.Id}", agentKey, StringComparison.Ordinal));

        if (participating is not null)
        {
            return participating;
        }

        return JobStatus.Agents.FirstOrDefault(agent =>
            string.Equals($"{agent.Telemetry.AgentId.Address}/{agent.Telemetry.AgentId.Id}", agentKey, StringComparison.Ordinal));
    }

    private static string GetOutcomeBadgeClass(string? outcome) => outcome?.ToLowerInvariant() switch
    {
        var value when value is not null && value.StartsWith("completed") => "bg-success",
        "timed_out_requeued" => "bg-warning text-dark",
        "assigned" => "bg-secondary",
        _ => "bg-dark"
    };

    private static string FormatOutcome(string? outcome)
    {
        if (string.IsNullOrWhiteSpace(outcome))
        {
            return "Unknown";
        }

        return outcome.Replace('_', ' ');
    }

    private static string FormatDurationSeconds(double seconds) => $"{seconds:F2} s";

    private static string FormatGpuHashrate(long hashrate)
        => hashrate < 0 ? "Unknown" : $"{hashrate:N0} H/s";

    private static string FormatIntMetric(int value, string unit)
        => value < 0 ? "Unknown" : $"{value} {unit}";

    private static string FormatVramMetric(long usedBytes, long totalBytes, int utilization)
    {
        if (usedBytes < 0 && totalBytes <= 0 && utilization < 0)
        {
            return "Unknown";
        }

        var used = usedBytes >= 0 ? FormatBytes(usedBytes) : "?";
        var total = totalBytes > 0 ? FormatBytes(totalBytes) : "?";
        var util = utilization >= 0 ? $" ({utilization}%)" : string.Empty;
        return $"{used} / {total}{util}";
    }

    private static string FormatRejectRate(float? rejectRate)
    {
        if (!rejectRate.HasValue || float.IsNaN(rejectRate.Value))
        {
            return "Unknown";
        }

        return $"{rejectRate.Value * 100:F2} %";
    }

    private static string FormatAverageGpuUtilization(IEnumerable<GpuDeviceTelemetry>? devices)
    {
        if (devices is null)
        {
            return "Unknown";
        }

        var usable = devices.Where(d => d.GpuUtilization >= 0).Select(d => d.GpuUtilization).ToList();
        if (usable.Count == 0)
        {
            return "Unknown";
        }

        return $"{usable.Average():F1} %";
    }

    private static string FormatAverageVramUsage(IEnumerable<GpuDeviceTelemetry>? devices)
    {
        if (devices is null)
        {
            return "Unknown";
        }

        var usable = devices.Where(d => d.VramUsedBytes >= 0 && d.VramTotalBytes > 0).ToList();
        if (usable.Count == 0)
        {
            return "Unknown";
        }

        var avgUsed = (long)usable.Average(d => d.VramUsedBytes);
        var avgTotal = (long)usable.Average(d => d.VramTotalBytes);
        var util = avgTotal > 0 ? (int)Math.Round(avgUsed * 100.0 / avgTotal) : -1;
        return $"{FormatBytes(avgUsed)} / {FormatBytes(avgTotal)}" + (util >= 0 ? $" ({util}%)" : string.Empty);
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes < 0)
        {
            return "Unknown";
        }

        if (bytes < 1024)
        {
            return $"{bytes} B";
        }

        var value = (double)bytes;
        if (bytes < 1024 * 1024)
        {
            return $"{value / 1024.0:F1} KiB";
        }

        if (bytes < 1024L * 1024L * 1024L)
        {
            return $"{value / (1024.0 * 1024.0):F1} MiB";
        }

        return $"{value / (1024.0 * 1024.0 * 1024.0):F1} GiB";
    }
}